<section class="content-header">
  <div class="container-fluid">
    <div class="row mb-2">
      <div class="col-sm-7">
        <h1>
          <i class="fas fa-file-alt mr-2"></i>
          Application Result
        </h1>
      </div>

      <div class="col-sm-5">
        <ol class="breadcrumb float-sm-right">
          <li class="breadcrumb-item">
            <a href="/applicant/dashboard">
              Dashboard
            </a>
          </li>
          <li class="breadcrumb-item active">
            Check Result
          </li>
        </ol>
      </div>
    </div>
  </div>
</section>

<section class="content">
  <div class="container-fluid">
    <div class="card card-outline card-info">
      <div class="card-body text-center py-5">
        <div class="mb-4">
          <span
            class="d-inline-flex align-items-center justify-content-center rounded-circle bg-light"
            style="width:90px;height:90px"
          >
            <i
              class="fas fa-hourglass-half fa-3x text-info"
            ></i>
          </span>
        </div>

        <h3>No Result Available Yet</h3>

        <p class="text-muted mx-auto mb-4" style="max-width:650px">
          Your application result has not been released yet.
          Once the College completes the assessment and publishes
          the result, it will appear on this page.
        </p>

        <div class="alert alert-light border mx-auto" style="max-width:650px">
          Please check again later. You will also be able to see
          any relevant admission decision or further instruction
          from your application dashboard.
        </div>

        <a
          href="/applicant/dashboard"
          class="btn btn-success"
        >
          <i class="fas fa-arrow-left mr-1"></i>
          Back to Dashboard
        </a>
      </div>
    </div>
  </div>
</section>
