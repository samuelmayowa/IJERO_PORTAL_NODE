<section class="content-header">
  <div class="container-fluid">
    <div class="row mb-2">
      <div class="col-sm-8">
        <h1>
          <i class="fas fa-file-signature mr-2"></i>
          <%= form.title %>
        </h1>
      </div>

      <div class="col-sm-4">
        <ol class="breadcrumb float-sm-right">
          <li class="breadcrumb-item">
            <a href="/applicant/dashboard">Dashboard</a>
          </li>
          <li class="breadcrumb-item active">
            Application
          </li>
        </ol>
      </div>
    </div>
  </div>
</section>

<section class="content">
  <div class="container-fluid">

    <% if (
      typeof messages !== 'undefined' &&
      messages &&
      messages.error
    ) { %>
      <div class="alert alert-danger">
        <i class="fas fa-exclamation-triangle mr-1"></i>
        <%= messages.error %>
      </div>
    <% } %>

    <% if (
      typeof messages !== 'undefined' &&
      messages &&
      messages.success
    ) { %>
      <div class="alert alert-success">
        <i class="fas fa-check-circle mr-1"></i>
        <%= messages.success %>
      </div>
    <% } %>

    <div class="card card-outline card-success">
      <div class="card-header">
        <h3 class="card-title">
          Application Information
        </h3>
      </div>

      <div class="card-body">
        <div class="row">
          <div class="col-md-8">
            <h4><%= form.title %></h4>

            <p class="text-muted">
              <strong>Category:</strong>
              <%= form.category || 'General' %>
              &nbsp; |
              <strong>Session:</strong>
              <%= form.session_name || '-' %>
            </p>

            <p>
              <%= form.description || 'No description has been provided.' %>
            </p>

            <% if (form.instructions) { %>
              <div class="alert alert-info">
                <strong>Instructions</strong>

                <div
                  class="mt-1"
                  style="
                    white-space: pre-line;
                    overflow-wrap: anywhere;
                    display: -webkit-box;
                    -webkit-box-orient: vertical;
                    -webkit-line-clamp: 5;
                    overflow: hidden;
                    line-height: 1.5;
                  "
                ><%= form.instructions %></div>
              </div>
            <% } %>
          </div>

          <div class="col-md-4">
            <div class="callout callout-info">
              <strong>Application Window</strong><br>
              Opens:
              <%= new Date(form.opens_at).toLocaleString() %><br>
              Closes:
              <%= new Date(form.closes_at).toLocaleString() %>
            </div>
          </div>
        </div>

        <hr>

        <div class="row">
          <div class="col-md-6">
            <h5>Application Charges</h5>

            <table class="table table-sm table-bordered">
              <tbody>
                <% form.application_charges.forEach((charge) => { %>
                  <tr>
                    <td><%= charge.charge_name %></td>
                    <td class="text-right">
                      ₦<%= Number(charge.amount || 0).toLocaleString(
                        'en-NG',
                        {
                          minimumFractionDigits: 2,
                          maximumFractionDigits: 2
                        }
                      ) %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>

              <tfoot>
                <tr>
                  <th>Total Payable</th>
                  <th class="text-right">
                    ₦<%= Number(form.application_total || 0).toLocaleString(
                      'en-NG',
                      {
                        minimumFractionDigits: 2,
                        maximumFractionDigits: 2
                      }
                    ) %>
                  </th>
                </tr>
              </tfoot>
            </table>
          </div>

          <div class="col-md-6" id="eligibility">
            <h5>Eligibility Verification</h5>

            <div class="alert <%= eligibility.eligible
              ? 'alert-success'
              : eligibility.requires_reference_verification
                ? 'alert-info'
                : 'alert-danger' %>">
              <i class="fas <%= eligibility.eligible
                ? 'fa-check-circle'
                : eligibility.requires_reference_verification
                  ? 'fa-info-circle'
                  : 'fa-times-circle' %> mr-1"></i>

              <strong>
                <%= eligibility.eligible
                  ? 'JAMB Record Verified'
                  : eligibility.requires_reference_verification
                    ? 'Verification Required'
                    : 'Not Eligible to Apply' %>
              </strong>

              <br>
              <%= eligibility.reason %>
            </div>

            <% if (
              !eligibility.eligible &&
              eligibility.requires_reference_verification
            ) { %>
              <form
                method="POST"
                action="/applicant/applications/<%= encodeURIComponent(
                  form.slug
                ) %>/verify-prerequisite"
                class="border rounded p-3 mb-3"
              >
                <% if (csrfToken) { %>
                  <input
                    type="hidden"
                    name="_csrf"
                    value="<%= csrfToken %>"
                  >
                <% } %>

                <div class="form-group">
                  <label>JAMB Registration Number</label>

                  <input
                    type="text"
                    name="jamb_registration_number"
                    class="form-control"
                    required
                    maxlength="100"
                    autocomplete="off"
                    placeholder="Enter your JAMB registration number"
                  >
                </div>

                <button class="btn btn-primary">
                  <i class="fas fa-shield-alt mr-1"></i>
                  Verify JAMB Record
                </button>
              </form>

              <p class="text-muted small">
                Enter the registration number exactly as it appears on
                your JAMB record. Your information will be verified
                securely against the approved candidate list and your
                portal profile.
              </p>
            <% } %>

            <% if (
              eligibility.eligible &&
              eligibility.verified_record
            ) { %>
              <% const candidate =
                eligibility.verified_record; %>

              <div class="card card-outline card-success mt-3">
                <div class="card-header">
                  <h3 class="card-title">
                    <i class="fas fa-user-check mr-1"></i>
                    Verified JAMB Candidate Record
                  </h3>
                </div>

                <div class="card-body p-0">
                  <table class="table table-bordered mb-0">
                    <tbody>
                      <tr>
                        <th style="width:42%">First Name</th>
                        <td><%= candidate.first_name || '-' %></td>
                      </tr>

                      <tr>
                        <th>Middle Name</th>
                        <td><%= candidate.middle_name || '-' %></td>
                      </tr>

                      <tr>
                        <th>Surname</th>
                        <td><%= candidate.surname || '-' %></td>
                      </tr>

                      <tr>
                        <th>JAMB Registration Number</th>
                        <td>
                          <strong>
                            <%= candidate.candidate_reference || '-' %>
                          </strong>
                        </td>
                      </tr>

                      <tr>
                        <th>State of Origin</th>
                        <td>
                          <%= candidate.state_of_origin || '-' %>
                        </td>
                      </tr>

                      <tr>
                        <th>Local Government Area</th>
                        <td><%= candidate.lga || '-' %></td>
                      </tr>

                      <tr>
                        <th>Gender</th>
                        <td><%= candidate.gender || '-' %></td>
                      </tr>

                      <tr>
                        <th>JAMB Total Score</th>
                        <td>
                          <%= candidate.jamb_total_score ?? '-' %>
                        </td>
                      </tr>
                    </tbody>
                  </table>
                </div>

                <div class="card-footer text-muted small">
                  These verified details are read-only and will be
                  carried into the payment and application process.
                </div>
              </div>
            <% } %>

            <% if (Number(form.requires_prerequisite) !== 1) { %>
              <small class="text-muted">
                This application is open to all registered applicants.
              </small>
            <% } %>
          </div>
        </div>
      </div>

      <div class="card-footer">
        <%
          const applicationProgress =
            typeof progress !== 'undefined'
              ? progress
              : null;

          const progressPaymentStatus =
            applicationProgress
              ? String(
                  applicationProgress.application_payment_status || ''
                ).toUpperCase()
              : '';

          const progressStatus =
            applicationProgress
              ? String(applicationProgress.status || '').toUpperCase()
              : '';
        %>

        <% if (!eligibility.eligible) { %>
          <button
            type="button"
            class="btn btn-secondary"
            disabled
          >
            Application Restricted
          </button>

        <% } else if (
          applicationProgress &&
          progressStatus === 'SUBMITTED'
        ) { %>
          <span class="badge badge-success p-2">
            <i class="fas fa-check-circle mr-1"></i>
            Application Submitted
          </span>

          <a
            href="/applicant/applications/<%= encodeURIComponent(
              form.slug
            ) %>/form"
            class="btn btn-outline-success ml-2"
          >
            View Application
          </a>

        <% } else if (
          applicationProgress &&
          ['PAID', 'NOT_REQUIRED'].includes(
            progressPaymentStatus
          )
        ) { %>
          <a
            href="/applicant/applications/<%= encodeURIComponent(
              form.slug
            ) %>/form"
            class="btn btn-success"
          >
            <i class="fas fa-edit mr-1"></i>
            Continue Application
          </a>

        <% } else if (
          applicationProgress &&
          applicationProgress.order_id
        ) { %>
          <a
            href="/payment/print/<%= encodeURIComponent(
              applicationProgress.order_id
            ) %>?type=invoice&dl=0"
            class="btn btn-warning"
          >
            <i class="fas fa-receipt mr-1"></i>
            View Payment Invoice
          </a>

          <form
            method="POST"
            action="/applicant/applications/<%= encodeURIComponent(
              form.slug
            ) %>/start"
            class="d-inline"
          >
            <% if (csrfToken) { %>
              <input
                type="hidden"
                name="_csrf"
                value="<%= csrfToken %>"
              >
            <% } %>

            <button class="btn btn-outline-primary ml-1">
              <i class="fas fa-sync mr-1"></i>
              Continue Payment
            </button>
          </form>

        <% } else { %>
          <form
            method="POST"
            action="/applicant/applications/<%= encodeURIComponent(
              form.slug
            ) %>/start"
            class="d-inline"
          >
            <% if (csrfToken) { %>
              <input
                type="hidden"
                name="_csrf"
                value="<%= csrfToken %>"
              >
            <% } %>

            <button class="btn btn-success">
              <i class="fas fa-play mr-1"></i>
              Start Application
            </button>
          </form>
        <% } %>

        <a
          href="/applicant/dashboard"
          class="btn btn-outline-secondary float-right"
        >
          Back to Dashboard
        </a>
      </div>
    </div>

  </div>
</section>
