<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title><%= typeof title === 'string' ? title : 'Staff Vacancy Application' %></title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="csrf-token" content="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">

  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.5.2/dist/css/bootstrap.min.css" crossorigin="anonymous">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">

  <style>
    :root{
      --brand-green:#247D57;
      --brand-green-deep:#195741;
      --brand-blue:#1f68c1;
      --brand-blue-soft:#eaf3ff;
      --brand-wine:#82103C;
      --ink:#1b2533;
      --muted:#6b7280;
      --line:#dbe3ee;
      --bg:#f4f8fc;
      --danger:#c0392b;
      --success:#1e824c;
      --warning:#f39c12;
    }

    *{box-sizing:border-box;}
    html,body{height:100%;}
    body{
      margin:0;
      font-family:"Segoe UI", Roboto, Arial, sans-serif;
      color:var(--ink);
      background:
        linear-gradient(rgba(255,255,255,.90), rgba(255,255,255,.92)),
        url('/public/img/login-bg.jpg') center/cover no-repeat fixed;
    }

    .page-shell{
      min-height:100vh;
      padding:28px 14px 50px;
    }

    .topbar{
      max-width:1180px;
      margin:0 auto 18px;
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:1rem;
      flex-wrap:wrap;
    }

    .brand-wrap{
      display:flex;
      align-items:center;
      gap:12px;
    }

    .brand-wrap img{
      width:62px;
      height:62px;
      object-fit:contain;
      border-radius:50%;
      background:#fff;
      border:2px solid rgba(36,125,87,.18);
      padding:6px;
      box-shadow:0 6px 18px rgba(0,0,0,.08);
    }

    .brand-text h1{
      margin:0;
      font-size:1.2rem;
      color:var(--brand-green-deep);
      font-weight:800;
      line-height:1.2;
    }

    .brand-text p{
      margin:4px 0 0;
      color:var(--muted);
      font-size:.93rem;
    }

    .top-actions a{
      display:inline-flex;
      align-items:center;
      gap:8px;
      text-decoration:none;
      background:#fff;
      color:var(--brand-green-deep);
      border:1px solid rgba(36,125,87,.16);
      border-radius:999px;
      padding:10px 16px;
      font-weight:700;
      box-shadow:0 8px 24px rgba(0,0,0,.05);
    }

    .top-actions a:hover{
      text-decoration:none;
      color:var(--brand-green-deep);
    }

    .hero-card{
      max-width:1180px;
      margin:0 auto 20px;
      border-radius:22px;
      overflow:hidden;
      background:linear-gradient(135deg, rgba(25,87,65,.98), rgba(31,104,193,.92));
      color:#fff;
      box-shadow:0 22px 60px rgba(21,50,84,.18);
      position:relative;
    }

    .hero-card::after{
      content:"";
      position:absolute;
      inset:auto -80px -80px auto;
      width:220px;
      height:220px;
      background:rgba(255,255,255,.08);
      border-radius:50%;
    }

    .hero-inner{
      display:grid;
      grid-template-columns:1.3fr .9fr;
      gap:24px;
      padding:30px 28px;
      position:relative;
      z-index:1;
    }

    .hero-kicker{
      display:inline-block;
      padding:6px 12px;
      background:rgba(255,255,255,.14);
      border:1px solid rgba(255,255,255,.16);
      border-radius:999px;
      font-size:.85rem;
      font-weight:700;
      letter-spacing:.03em;
      margin-bottom:14px;
    }

    .hero-title{
      font-size:2rem;
      line-height:1.18;
      margin:0 0 10px;
      font-weight:800;
    }

    .hero-text{
      max-width:760px;
      color:rgba(255,255,255,.92);
      font-size:1rem;
      line-height:1.6;
      margin:0;
    }

    .hero-points{
      display:grid;
      gap:12px;
      align-content:start;
    }

    .hero-point{
      background:rgba(255,255,255,.10);
      border:1px solid rgba(255,255,255,.14);
      border-radius:16px;
      padding:14px 16px;
    }

    .hero-point strong{
      display:block;
      margin-bottom:4px;
      font-size:.95rem;
    }

    .content-grid{
      max-width:1180px;
      margin:0 auto;
      display:grid;
      grid-template-columns:1.45fr .75fr;
      gap:22px;
    }

    .glass-card{
      background:rgba(255,255,255,.94);
      border:1px solid rgba(255,255,255,.65);
      border-radius:22px;
      box-shadow:0 18px 45px rgba(34,52,84,.08);
      overflow:hidden;
    }

    .card-head{
      padding:20px 22px;
      border-bottom:1px solid var(--line);
      background:linear-gradient(180deg, rgba(31,104,193,.06), rgba(36,125,87,.03));
    }

    .card-head h2{
      margin:0;
      font-size:1.22rem;
      font-weight:800;
      color:var(--ink);
    }

    .card-head p{
      margin:6px 0 0;
      color:var(--muted);
    }

    .card-body{
      padding:22px;
    }

    .form-section-title{
      display:flex;
      align-items:center;
      gap:10px;
      font-size:1rem;
      font-weight:800;
      color:var(--brand-green-deep);
      margin:0 0 14px;
    }

    .form-grid{
      display:grid;
      grid-template-columns:repeat(2, minmax(0, 1fr));
      gap:16px;
    }

    .full-span{
      grid-column:1 / -1;
    }

    .form-group label{
      font-weight:700;
      color:#243245;
      margin-bottom:8px;
    }

    .form-control,
    .custom-select{
      min-height:50px;
      border-radius:12px;
      border:1px solid #d8e1ea;
      box-shadow:none !important;
    }

    textarea.form-control{
      min-height:110px;
      resize:vertical;
    }

    .form-control:focus,
    .custom-select:focus{
      border-color:#7eb1ea;
      box-shadow:0 0 0 3px rgba(31,104,193,.12) !important;
    }

    .field-note{
      display:block;
      margin-top:6px;
      color:var(--muted);
      font-size:.84rem;
    }

    .upload-grid{
      display:grid;
      grid-template-columns:repeat(3, minmax(0, 1fr));
      gap:14px;
    }

    .upload-card{
      border:1px dashed #bed2ea;
      background:#f8fbff;
      border-radius:16px;
      padding:16px;
      min-height:100%;
    }

    .upload-card .icon{
      width:44px;
      height:44px;
      border-radius:12px;
      background:var(--brand-blue-soft);
      color:var(--brand-blue);
      display:flex;
      align-items:center;
      justify-content:center;
      font-size:1.1rem;
      margin-bottom:10px;
    }

    .upload-card h4{
      margin:0 0 6px;
      font-size:1rem;
      font-weight:800;
    }

    .upload-card p{
      margin:0 0 12px;
      color:var(--muted);
      font-size:.9rem;
      line-height:1.45;
    }

    .upload-card input[type="file"]{
      display:block;
      width:100%;
      font-size:.92rem;
    }

    .check-wrap{
      display:flex;
      align-items:flex-start;
      gap:10px;
      padding:14px 16px;
      border-radius:14px;
      background:#f7fbf9;
      border:1px solid #dcefe5;
    }

    .check-wrap input{
      margin-top:4px;
    }

    .action-row{
      display:flex;
      align-items:center;
      gap:12px;
      flex-wrap:wrap;
      margin-top:20px;
    }

    .btn-submit{
      min-width:220px;
      border:0;
      border-radius:12px;
      background:linear-gradient(135deg, var(--brand-wine), #a20d4a);
      color:#fff;
      font-weight:800;
      padding:13px 20px;
      box-shadow:0 14px 28px rgba(130,16,60,.18);
    }

    .btn-submit:hover{
      color:#fff;
      filter:brightness(.98);
    }

    .btn-light-alt{
      border-radius:12px;
      padding:12px 18px;
      font-weight:700;
      border:1px solid #d8e1ea;
      background:#fff;
      color:#223147;
    }

    .tiny-meta{
      color:var(--muted);
      font-size:.88rem;
    }

    .alert-box{
      display:none;
      margin-bottom:18px;
      border-radius:14px;
      padding:14px 16px;
      font-weight:600;
      border:1px solid transparent;
    }

    .alert-box.show{display:block;}
    .alert-box.alert-danger{
      background:#fff5f3;
      border-color:#f2c0b8;
      color:#8b2c1d;
    }
    .alert-box.alert-success{
      background:#edf9f1;
      border-color:#bfe2c8;
      color:#1d6a38;
    }
    .alert-box.alert-warning{
      background:#fff9ed;
      border-color:#f7ddb1;
      color:#8a5a00;
    }

    .invalid-feedback{
      display:block;
      margin-top:6px;
      font-size:.84rem;
      font-weight:600;
    }

    .info-stack{
      display:grid;
      gap:16px;
    }

    .info-box{
      border-radius:18px;
      padding:18px;
      background:rgba(255,255,255,.94);
      border:1px solid var(--line);
      box-shadow:0 14px 34px rgba(34,52,84,.06);
    }

    .info-box h3{
      margin:0 0 10px;
      font-size:1rem;
      font-weight:800;
      color:var(--brand-green-deep);
    }

    .info-box p,
    .info-box li{
      color:#4e5e72;
      font-size:.94rem;
      line-height:1.55;
    }

    .info-box ul{
      padding-left:18px;
      margin:0;
    }

    .pill{
      display:inline-flex;
      align-items:center;
      gap:8px;
      padding:8px 12px;
      border-radius:999px;
      background:var(--brand-blue-soft);
      color:var(--brand-blue);
      font-weight:700;
      font-size:.85rem;
      margin-bottom:8px;
    }

    .requirement-box{
      margin-top:18px;
      border:1px solid #dbe7f2;
      border-radius:18px;
      overflow:hidden;
      background:#fbfdff;
    }

    .requirement-head{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:12px;
      padding:16px 18px;
      background:linear-gradient(180deg, rgba(31,104,193,.06), rgba(36,125,87,.03));
      border-bottom:1px solid #dbe7f2;
    }

    .requirement-head h4{
      margin:0;
      font-size:1rem;
      font-weight:800;
      color:#174a8a;
    }

    .requirement-head p{
      margin:4px 0 0;
      color:var(--muted);
      font-size:.9rem;
    }

    .requirement-list{
      display:grid;
      max-height:420px;
      overflow:auto;
    }

    .requirement-row{
      display:grid;
      grid-template-columns:110px 1fr;
      gap:12px;
      align-items:center;
      padding:14px 18px;
      border-bottom:1px solid #edf2f7;
    }

    .requirement-row:last-child{
      border-bottom:none;
    }

    .req-title{
      font-weight:700;
      color:#26374c;
      line-height:1.5;
    }

    .btn-view-req{
      border:0;
      border-radius:10px;
      background:linear-gradient(135deg, #1f68c1, #2f80ed);
      color:#fff;
      font-weight:800;
      padding:10px 14px;
      box-shadow:0 10px 24px rgba(31,104,193,.14);
    }

    .btn-view-req:hover{
      color:#fff;
      filter:brightness(.98);
    }

    .modal-shell{
      position:fixed;
      inset:0;
      display:none;
      align-items:center;
      justify-content:center;
      padding:18px;
      z-index:9999;
    }

    .modal-shell.open{
      display:flex;
    }

    .modal-backdrop{
      position:absolute;
      inset:0;
      background:rgba(10,18,30,.40);
    }

    .modal-card{
      position:relative;
      z-index:10;
      width:min(760px, 100%);
      border-radius:24px;
      overflow:hidden;
      background:#ffffff;
      box-shadow:0 28px 80px rgba(0,0,0,.28);
      max-height:90vh;
      overflow-y:auto;
      opacity:1 !important;
      filter:none !important;
      backdrop-filter:none !important;
      transform:translateZ(0);
      isolation:isolate;
      pointer-events:auto;
    }

    .modal-card *{
      filter:none !important;
      backdrop-filter:none !important;
    }

    .modal-top{
      padding:24px 24px 18px;
      text-align:center;
      background:linear-gradient(135deg, rgba(31,104,193,.95), rgba(36,125,87,.96));
      color:#fff;
    }

    .success-icon{
      width:74px;
      height:74px;
      margin:0 auto 12px;
      border-radius:50%;
      background:rgba(255,255,255,.16);
      border:1px solid rgba(255,255,255,.22);
      display:flex;
      align-items:center;
      justify-content:center;
      font-size:2rem;
    }

    .modal-top h3{
      margin:0;
      font-size:1.45rem;
      font-weight:800;
    }

    .modal-top p{
      margin:8px auto 0;
      max-width:560px;
      color:rgba(255,255,255,.92);
    }

    .modal-body{
      padding:22px;
    }

    .summary-grid{
      display:grid;
      grid-template-columns:repeat(2, minmax(0, 1fr));
      gap:12px;
      margin-bottom:18px;
    }

    .summary-item{
      border:1px solid var(--line);
      border-radius:14px;
      padding:14px;
      background:#fbfdff;
    }

    .summary-item .k{
      font-size:.82rem;
      color:var(--muted);
      text-transform:uppercase;
      letter-spacing:.04em;
      margin-bottom:5px;
      font-weight:700;
    }

    .summary-item .v{
      font-weight:800;
      color:#223147;
      line-height:1.45;
      word-break:break-word;
    }

    .modal-actions{
      display:flex;
      gap:12px;
      flex-wrap:wrap;
      align-items:center;
    }

    .modal-actions-top{
      justify-content:flex-end;
      padding:4px 0 2px;
    }

    .btn-print{
      background:linear-gradient(135deg, var(--brand-blue), #4285f4);
      color:#fff;
      border:0;
      border-radius:12px;
      padding:12px 18px;
      font-weight:800;
      cursor:pointer;
    }

    .btn-print:hover{color:#fff;}

    .btn-close-modal{
      background:#fff;
      color:#223147;
      border:1px solid #d8e1ea;
      border-radius:12px;
      padding:12px 18px;
      font-weight:800;
      cursor:pointer;
    }

    .req-modal-copy{
      white-space:pre-line;
      color:#24364a;
      line-height:1.8;
      font-size:1rem;
      background:#ffffff;
      border:1px solid #dbe7f8;
      border-radius:16px;
      padding:18px;
    }

    #printSheet{
      display:none;
    }

    .print-slip{
      position:relative;
      background:#ffffff;
      border:1px solid #b9d0f5;
      border-radius:24px;
      overflow:hidden;
      padding:28px;
      filter:none !important;
      backdrop-filter:none !important;
      opacity:1 !important;
    }

    .print-slip::before{
      content:attr(data-watermark);
      position:absolute;
      inset:0;
      display:flex;
      align-items:center;
      justify-content:center;
      font-size:3rem;
      line-height:1.1;
      text-align:center;
      color:rgba(31,104,193,.10);
      font-weight:900;
      letter-spacing:.08em;
      transform:rotate(-24deg);
      pointer-events:none;
      padding:30px;
    }

    .print-head{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:16px;
      margin-bottom:18px;
      position:relative;
      z-index:1;
    }

    .print-head .left{
      display:flex;
      align-items:center;
      gap:14px;
    }

    .print-head img{
      width:62px;
      height:62px;
      object-fit:contain;
    }

    .print-head h4{
      margin:0;
      font-size:1.08rem;
      color:#174a8a;
      font-weight:900;
    }

    .print-head p{
      margin:4px 0 0;
      color:#44627a;
      font-size:.9rem;
    }

    .print-badge{
      padding:10px 14px;
      border-radius:999px;
      background:#eef5ff;
      color:#1f68c1;
      font-weight:800;
      border:1px solid #c9dbfb;
      white-space:nowrap;
    }

    .print-body{
      position:relative;
      z-index:1;
      border-top:1px solid #dbe7fb;
      padding-top:18px;
    }

    .print-row{
      display:grid;
      grid-template-columns:220px 1fr;
      gap:12px;
      padding:9px 0;
      border-bottom:1px dashed #dbe7fb;
    }

    .print-row .label{
      color:#5a6c82;
      font-weight:700;
    }

    .print-row .value{
      color:#213249;
      font-weight:800;
      word-break:break-word;
    }

    .print-foot{
      position:relative;
      z-index:1;
      margin-top:16px;
      color:#51657d;
      font-size:.92rem;
      line-height:1.55;
    }

    .spinner-border-sm{
      margin-right:8px;
    }

    @media (max-width: 991px){
      .hero-inner,
      .content-grid{
        grid-template-columns:1fr;
      }
    }

    @media (max-width: 767px){
      .form-grid,
      .upload-grid,
      .summary-grid{
        grid-template-columns:1fr;
      }

      .print-row,
      .requirement-row{
        grid-template-columns:1fr;
        gap:4px;
      }

      .hero-title{
        font-size:1.6rem;
      }
    }

    @media print{
      body *{
        visibility:hidden !important;
      }

      #printSheet,
      #printSheet *{
        visibility:visible !important;
      }

      #printSheet{
        display:block !important;
        position:absolute;
        inset:0;
        width:100%;
        padding:18px;
      }

      .print-slip{
        box-shadow:none !important;
        border-color:#9ebdea !important;
      }
    }
  </style>
</head>
<body>
  <div class="page-shell">
    <div class="topbar">
      <div class="brand-wrap">
        <img src="/public/img/logo.png" alt="EKSCOTECH logo">
        <div class="brand-text">
          <h1><%= institutionName %></h1>
          <p>Welcome to the College staff vacancy application portal</p>
        </div>
      </div>

      <div class="top-actions">
        <a href="/"><i class="fa fa-home"></i> Back to Homepage</a>
      </div>
    </div>

    <section class="hero-card">
      <div class="hero-inner">
        <div>
          <span class="hero-kicker"><i class="fa fa-briefcase"></i> Staff Vacancy Application</span>
          <h2 class="hero-title">Apply for advertised positions online</h2>
          <p class="hero-text">
            Complete the form below carefully, upload your CV and supporting credentials,
            and submit your application directly through the portal. After a successful
            submission, you will receive a printable confirmation slip with your application
            reference number.
          </p>
        </div>

        <div class="hero-points">
          <div class="hero-point">
            <strong><i class="fa fa-check-circle"></i> No login required</strong>
            <span>This application page is open to the public.</span>
            <span style="color: red;">Application Closing Date: 29th/April/2026.</span>
          </div>
          <div class="hero-point">
            <strong><i class="fa fa-upload"></i> Upload requirements</strong>
            <span>CV is required. Educational certificates are required. Other supporting document is optional.</span>
          </div>
          <div class="hero-point">
            <strong><i class="fa fa-envelope-o"></i> Official contact</strong>
            <span><%= advertEmail %></span>
          </div>
        </div>
      </div>
    </section>

    <div class="content-grid">
      <section class="glass-card">
        <div class="card-head">
          <h2>Vacancy Application Form</h2>
          <p>Please fill all required fields correctly before submission.</p>
        </div>

        <div class="card-body">
          <div id="formAlert" class="alert-box" role="alert"></div>

          <form id="vacancyForm" action="/vacancies/apply" method="POST" enctype="multipart/form-data" novalidate>
            <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">

            <h3 class="form-section-title">
              <i class="fa fa-user-circle-o"></i> Personal Information
            </h3>

            <div class="form-grid">
              <div class="form-group">
                <label for="first_name">First Name <span class="text-danger">*</span></label>
                <input type="text" class="form-control" id="first_name" name="first_name" placeholder="Enter first name">
              </div>

              <div class="form-group">
                <label for="middle_name">Middle Name</label>
                <input type="text" class="form-control" id="middle_name" name="middle_name" placeholder="Enter middle name">
              </div>

              <div class="form-group">
                <label for="last_name">Last Name <span class="text-danger">*</span></label>
                <input type="text" class="form-control" id="last_name" name="last_name" placeholder="Enter last name">
              </div>

              <div class="form-group">
                <label for="gender">Gender</label>
                <select class="custom-select" id="gender" name="gender">
                  <option value="">Select gender</option>
                  <option value="Male">Male</option>
                  <option value="Female">Female</option>
                </select>
              </div>

              <div class="form-group">
                <label for="email">Email Address <span class="text-danger">*</span></label>
                <input type="email" class="form-control" id="email" name="email" placeholder="name@example.com">
              </div>

              <div class="form-group">
                <label for="phone">Phone Number <span class="text-danger">*</span></label>
                <input type="text" class="form-control" id="phone" name="phone" placeholder="e.g. 08012345678">
              </div>

              <div class="form-group">
                <label for="alternative_phone">Alternative Phone Number</label>
                <input type="text" class="form-control" id="alternative_phone" name="alternative_phone" placeholder="Optional">
              </div>

              <div class="form-group">
                <label for="date_of_birth">Date of Birth <span class="text-danger">*</span></label>
                <input type="date" class="form-control" id="date_of_birth" name="date_of_birth">
              </div>

              <div class="form-group">
                <label for="state_of_origin">State of Origin <span class="text-danger">*</span></label>
                <select class="custom-select" id="state_of_origin" name="state_of_origin">
                  <option value="">Select state of origin</option>
                  <% nigeriaStates.forEach(function(state){ %>
                    <option value="<%= state %>"><%= state %></option>
                  <% }) %>
                </select>
              </div>

              <div class="form-group">
                <label for="local_government">Local Government <span class="text-danger">*</span></label>
                <input type="text" class="form-control" id="local_government" name="local_government" placeholder="Enter LGA">
              </div>

              <div class="form-group full-span">
                <label for="house_address">House Address <span class="text-danger">*</span></label>
                <textarea class="form-control" id="house_address" name="house_address" placeholder="Enter full residential address"></textarea>
              </div>
            </div>

            <h3 class="form-section-title mt-4">
              <i class="fa fa-briefcase"></i> Position Details
            </h3>

            <div class="form-grid">
              <div class="form-group full-span">
                <label for="post_applying_for">Post Applying For <span class="text-danger">*</span></label>
                <select class="custom-select" id="post_applying_for" name="post_applying_for">
                  <option value="">Select advertised post</option>
                  <% vacancyGroups.forEach(function(group){ %>
                    <optgroup label="<%= group.label %>">
                      <% group.options.forEach(function(option){ %>
                        <option value="<%= option %>"><%= option %></option>
                      <% }) %>
                    </optgroup>
                  <% }) %>
                </select>
                <small class="field-note">Select the exact advertised post you are applying for.</small>
              </div>
            </div>

            <div class="requirement-box">
              <div class="requirement-head">
                <div>
                  <h4>REQUIREMENT:</h4>
                  <p>Click VIEW in front of any post to see the detailed requirement.</p>
                  <p style="color:red;">NOTE: The Vacancies List is scrollable, scroll to view more roles.</p>
                </div>
              </div>

              <div class="requirement-list">
                <% vacancyRequirements.forEach(function(item, index){ %>
                  <div class="requirement-row">
                    <div>
                      <button
                        type="button"
                        class="btn-view-req"
                        data-req-index="<%= index %>"
                      >
                        VIEW
                      </button>
                    </div>
                    <div class="req-title"><%= item.title %></div>
                  </div>
                <% }) %>
              </div>
            </div>

            <h3 class="form-section-title mt-4">
              <i class="fa fa-folder-open-o"></i> Required Uploads
            </h3>

            <div class="upload-grid">
              <div class="upload-card">
                <div class="icon"><i class="fa fa-file-pdf-o"></i></div>
                <h4>Upload CV <span class="text-danger">*</span></h4>
                <p>Accepted: PDF, DOC, DOCX. Maximum size: 5MB.</p>
                <input type="file" id="cv" name="cv" accept=".pdf,.doc,.docx">
              </div>

              <div class="upload-card">
                <div class="icon"><i class="fa fa-files-o"></i></div>
                <h4>Other Supporting Document</h4>
                <p>Optional. Accepted: PDF, DOC, DOCX, JPG, JPEG, PNG.</p>
                <input type="file" id="other_document" name="other_document" accept=".pdf,.doc,.docx,.jpg,.jpeg,.png">
              </div>

              <div class="upload-card">
                <div class="icon"><i class="fa fa-graduation-cap"></i></div>
                <h4>Educational Certificates <span class="text-danger">*</span></h4>
                <p>Upload one or more certificate files. Maximum 5 files, 5MB each.</p>
                <input type="file" id="certificates" name="certificates" accept=".pdf,.doc,.docx,.jpg,.jpeg,.png" multiple>
              </div>
            </div>

            <div class="check-wrap mt-4">
              <input type="checkbox" id="declaration" name="declaration" value="1">
              <label for="declaration" class="mb-0">
                I confirm that the information and uploaded documents provided in this application are true, correct, and belong to me.
              </label>
            </div>

            <div class="action-row">
              <button type="submit" class="btn btn-submit" id="submitBtn">
                <i class="fa fa-paper-plane-o"></i> Submit Application
              </button>
              <button type="reset" class="btn btn-light-alt">
                <i class="fa fa-refresh"></i> Reset Form
              </button>
              <span class="tiny-meta">Fields marked with <span class="text-danger">*</span> are required.</span>
            </div>
          </form>
        </div>
      </section>

      <aside class="info-stack">
        <div class="info-box">
          <div class="pill"><i class="fa fa-info-circle"></i> Important</div>
          <h3>Before you submit</h3>
          <ul>
            <li>Use a working email address and phone number.</li>
            <li>Choose the exact advertised post from the list.</li>
            <li>Ensure your CV is up to date.</li>
            <li>Upload at least one educational certificate.</li>
            <li>Keep your confirmation slip after successful submission.</li>
          </ul>
        </div>

        <div class="info-box">
          <div class="pill"><i class="fa fa-shield"></i> Validation</div>
          <h3>What the system checks</h3>
          <p>
            This page validates required fields, email address format, phone number format,
            minimum applicant age, and required document uploads before allowing submission.
          </p>
        </div>

        <div class="info-box">
          <div class="pill"><i class="fa fa-print"></i> Confirmation Slip</div>
          <h3>After submission</h3>
          <p>
            A success modal will appear immediately with your application reference number,
            post applied for, and submission time. You can print the confirmation slip directly.
          </p>
        </div>
      </aside>
    </div>
  </div>

  <div class="modal-shell" id="requirementModal" aria-hidden="true">
    <div class="modal-backdrop" onclick="window.closeRequirementModalNow(event)"></div>

    <div class="modal-card" onclick="event.stopPropagation()">
      <div class="modal-top">
        <div class="success-icon">
          <i class="fa fa-list-alt"></i>
        </div>
        <h3 id="reqModalTitle">Requirement</h3>
        <p>Detailed requirement for the selected advertised post.</p>
      </div>

      <div class="modal-body">
        <div class="req-modal-copy" id="reqModalBody"></div>

        <div class="modal-actions mt-3">
          <button
            type="button"
            class="btn btn-close-modal"
            id="closeReqModalBtn"
            onclick="window.closeRequirementModalNow(event)"
          >
            <i class="fa fa-times"></i> Close
          </button>
        </div>
      </div>
    </div>
  </div>

  <div class="modal-shell" id="successModal" aria-hidden="true">
    <div class="modal-backdrop" onclick="window.closeSuccessModalNow(event)"></div>

    <div class="modal-card" onclick="event.stopPropagation()">
      <div class="modal-top">
        <div class="success-icon">
          <i class="fa fa-check"></i>
        </div>
        <h3>Application Submitted Successfully</h3>
        <p>
          Your vacancy application has been received successfully. Please print or save
          your submission confirmation slip.
        </p>
      </div>

      <div class="modal-body">
        <div class="summary-grid">
          <div class="summary-item">
            <div class="k">Reference Number</div>
            <div class="v" id="m_reference_no">-</div>
          </div>

          <div class="summary-item">
            <div class="k">Applicant Name</div>
            <div class="v" id="m_applicant_name">-</div>
          </div>

          <div class="summary-item">
            <div class="k">Post Applied For</div>
            <div class="v" id="m_post">-</div>
          </div>

          <div class="summary-item">
            <div class="k">Submitted At</div>
            <div class="v" id="m_submitted_at">-</div>
          </div>
        </div>

        <div class="modal-actions modal-actions-top mb-3">
          <button
            type="button"
            class="btn btn-print"
            id="printSlipBtnTop"
            onclick="window.triggerPrintDownloadNow(event)"
          >
            <i class="fa fa-print"></i> Print / Download Confirmation Slip
          </button>

          <button
            type="button"
            class="btn btn-close-modal"
            id="closeModalBtnTop"
            onclick="window.closeSuccessModalNow(event)"
          >
            <i class="fa fa-times"></i> Close
          </button>
        </div>

        <div class="print-slip" id="modalPrintPreview" data-watermark="<%= institutionName %>">
          <div class="print-head">
            <div class="left">
              <img src="/public/img/logo.png" alt="logo">
              <div>
                <h4><%= institutionName %></h4>
                <p>Staff Vacancy Application Submission Confirmation</p>
              </div>
            </div>
            <div class="print-badge">Submitted</div>
          </div>

          <div class="print-body">
            <div class="print-row">
              <div class="label">Application Reference No.</div>
              <div class="value" id="p_reference_no">-</div>
            </div>
            <div class="print-row">
              <div class="label">Applicant Name</div>
              <div class="value" id="p_applicant_name">-</div>
            </div>
            <div class="print-row">
              <div class="label">Post Applied For</div>
              <div class="value" id="p_post">-</div>
            </div>
            <div class="print-row">
              <div class="label">Email Address</div>
              <div class="value" id="p_email">-</div>
            </div>
            <div class="print-row">
              <div class="label">Phone Number</div>
              <div class="value" id="p_phone">-</div>
            </div>
            <div class="print-row">
              <div class="label">Date / Time Submitted</div>
              <div class="value" id="p_submitted_at">-</div>
            </div>
          </div>

          <div class="print-foot">
            Please keep this slip as evidence of successful submission.
            Only shortlisted candidates will be contacted by the institution.
          </div>
        </div>

        <div class="modal-actions mt-3">
          <button
            type="button"
            class="btn btn-print"
            id="printSlipBtn"
            onclick="window.triggerPrintDownloadNow(event)"
          >
            <i class="fa fa-print"></i> Print / Download Confirmation Slip
          </button>

          <button
            type="button"
            class="btn btn-close-modal"
            id="closeModalBtn"
            onclick="window.closeSuccessModalNow(event)"
          >
            <i class="fa fa-times"></i> Close
          </button>
        </div>
      </div>
    </div>
  </div>

  <div id="printSheet">
    <div class="print-slip" id="printOnlySlip" data-watermark="<%= institutionName %>">
      <div class="print-head">
        <div class="left">
          <img src="/public/img/logo.png" alt="logo">
          <div>
            <h4><%= institutionName %></h4>
            <p>Staff Vacancy Application Submission Confirmation</p>
          </div>
        </div>
        <div class="print-badge">Submitted</div>
      </div>

      <div class="print-body">
        <div class="print-row">
          <div class="label">Application Reference No.</div>
          <div class="value" id="pp_reference_no">-</div>
        </div>
        <div class="print-row">
          <div class="label">Applicant Name</div>
          <div class="value" id="pp_applicant_name">-</div>
        </div>
        <div class="print-row">
          <div class="label">Post Applied For</div>
          <div class="value" id="pp_post">-</div>
        </div>
        <div class="print-row">
          <div class="label">Email Address</div>
          <div class="value" id="pp_email">-</div>
        </div>
        <div class="print-row">
          <div class="label">Phone Number</div>
          <div class="value" id="pp_phone">-</div>
        </div>
        <div class="print-row">
          <div class="label">Date / Time Submitted</div>
          <div class="value" id="pp_submitted_at">-</div>
        </div>
      </div>

      <div class="print-foot">
        This slip confirms that the application was submitted successfully through the vacancy portal.
      </div>
    </div>
  </div>

  <script>
    const requirementData = <%- JSON.stringify(vacancyRequirements || []) %>;

    const form = document.getElementById('vacancyForm');
    const submitBtn = document.getElementById('submitBtn');
    const alertBox = document.getElementById('formAlert');
    const successModal = document.getElementById('successModal');
    const requirementModal = document.getElementById('requirementModal');

    function showAlert(type, message) {
      alertBox.className = 'alert-box show alert-' + type;
      alertBox.innerHTML = message;
      alertBox.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }

    function clearAlert() {
      alertBox.className = 'alert-box';
      alertBox.innerHTML = '';
    }

    function setLoading(loading) {
      submitBtn.disabled = loading;
      submitBtn.innerHTML = loading
        ? '<span class="spinner-border spinner-border-sm"></span>Submitting...'
        : '<i class="fa fa-paper-plane-o"></i> Submit Application';
    }

    function clearFieldErrors() {
      form.querySelectorAll('.is-invalid').forEach((el) => el.classList.remove('is-invalid'));
      form.querySelectorAll('.invalid-feedback.dynamic').forEach((el) => el.remove());
    }

    function setFieldError(fieldName, message) {
      const field = form.elements[fieldName];
      if (!field) return;

      field.classList.add('is-invalid');

      const error = document.createElement('div');
      error.className = 'invalid-feedback dynamic';
      error.textContent = message;

      if (field.type === 'checkbox') {
        field.closest('.check-wrap').insertAdjacentElement('afterend', error);
      } else if (field.closest('.upload-card')) {
        field.closest('.upload-card').appendChild(error);
      } else {
        field.parentNode.appendChild(error);
      }
    }

    function isValidEmail(value) {
      return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value);
    }

    function isValidPhone(value) {
      return /^[0-9+()\\-\\s]{10,20}$/.test(value);
    }

    function calculateAge(dateString) {
      const dob = new Date(dateString);
      if (Number.isNaN(dob.getTime())) return 0;

      const today = new Date();
      let age = today.getFullYear() - dob.getFullYear();
      const monthDiff = today.getMonth() - dob.getMonth();

      if (monthDiff < 0 || (monthDiff === 0 && today.getDate() < dob.getDate())) {
        age -= 1;
      }

      return age;
    }

    function validateClientSide() {
      clearFieldErrors();
      clearAlert();

      const errors = {};
      const firstName = form.first_name.value.trim();
      const lastName = form.last_name.value.trim();
      const email = form.email.value.trim();
      const phone = form.phone.value.trim();
      const alternativePhone = form.alternative_phone.value.trim();
      const dob = form.date_of_birth.value.trim();
      const state = form.state_of_origin.value.trim();
      const lga = form.local_government.value.trim();
      const address = form.house_address.value.trim();
      const post = form.post_applying_for.value.trim();

      const allowedPosts = new Set(requirementData.map((item) => item.title));

      if (!firstName) errors.first_name = 'First name is required.';
      if (!lastName) errors.last_name = 'Last name is required.';

      if (!email) {
        errors.email = 'Email address is required.';
      } else if (!isValidEmail(email)) {
        errors.email = 'Please enter a valid email address.';
      }

      if (!phone) {
        errors.phone = 'Phone number is required.';
      } else if (!isValidPhone(phone)) {
        errors.phone = 'Please enter a valid phone number.';
      }

      if (alternativePhone && !isValidPhone(alternativePhone)) {
        errors.alternative_phone = 'Please enter a valid alternative phone number.';
      }

      if (!dob) {
        errors.date_of_birth = 'Date of birth is required.';
      } else if (calculateAge(dob) < 18) {
        errors.date_of_birth = 'Applicant must be at least 18 years old.';
      }

      if (!state) errors.state_of_origin = 'State of origin is required.';
      if (!lga) errors.local_government = 'Local government is required.';
      if (!address) errors.house_address = 'House address is required.';

      if (!post) {
        errors.post_applying_for = 'Please select the post you are applying for.';
      } else if (!allowedPosts.has(post)) {
        errors.post_applying_for = 'Selected post is invalid.';
      }

      if (!form.cv.files.length) {
        errors.cv = 'CV upload is required.';
      }

      if (!form.certificates.files.length) {
        errors.certificates = 'Upload at least one educational certificate.';
      }

      if (!form.declaration.checked) {
        errors.declaration = 'You must confirm that the information provided is correct.';
      }

      Object.entries(errors).forEach(([key, value]) => setFieldError(key, value));

      if (Object.keys(errors).length) {
        showAlert('danger', 'Please correct the highlighted fields before submitting.');
        return false;
      }

      return true;
    }

    function fillSuccessData(data) {
      const mapping = {
        m_reference_no: data.reference_no,
        p_reference_no: data.reference_no,
        pp_reference_no: data.reference_no,

        m_applicant_name: data.applicant_name,
        p_applicant_name: data.applicant_name,
        pp_applicant_name: data.applicant_name,

        m_post: data.post_applying_for,
        p_post: data.post_applying_for,
        pp_post: data.post_applying_for,

        m_submitted_at: data.submitted_at_display,
        p_submitted_at: data.submitted_at_display,
        pp_submitted_at: data.submitted_at_display,

        p_email: data.email,
        pp_email: data.email,

        p_phone: data.phone,
        pp_phone: data.phone
      };

      Object.entries(mapping).forEach(([id, value]) => {
        const el = document.getElementById(id);
        if (el) el.textContent = value || '-';
      });
    }

    function openSuccessModal() {
      successModal.classList.add('open');
      successModal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }

    function closeSuccessModal() {
      successModal.classList.remove('open');
      successModal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    function openRequirementModal(title, requirement) {
      document.getElementById('reqModalTitle').textContent = title || 'Requirement';
      document.getElementById('reqModalBody').textContent = requirement || 'No requirement available.';
      requirementModal.classList.add('open');
      requirementModal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }

    function closeRequirementModal() {
      requirementModal.classList.remove('open');
      requirementModal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      if (!validateClientSide()) return;

      const formData = new FormData(form);

      try {
        setLoading(true);

        const response = await fetch(form.action, {
          method: 'POST',
          body: formData,
          headers: {
            Accept: 'application/json'
          }
        });

        const payload = await response.json().catch(() => ({
          ok: false,
          message: 'Unexpected server response.'
        }));

        if (!response.ok || !payload.ok) {
          clearFieldErrors();

          if (payload.errors && typeof payload.errors === 'object') {
            Object.entries(payload.errors).forEach(([key, value]) => {
              setFieldError(key, value);
            });
          }

          showAlert('danger', payload.message || 'Submission failed. Please try again.');
          return;
        }

        clearFieldErrors();
        fillSuccessData(payload.data);
        showAlert('success', payload.message || 'Application submitted successfully.');
        form.reset();
        openSuccessModal();
      } catch (error) {
        showAlert(
          'danger',
          'A network or server error occurred while submitting your application. Please try again.'
        );
      } finally {
        setLoading(false);
      }
    });

    function triggerPrintDownload() {
      const printSource = document.getElementById('printOnlySlip');

      if (!printSource) {
        alert('Print slip content not found.');
        return;
      }

      const iframe = document.createElement('iframe');
      iframe.style.position = 'fixed';
      iframe.style.right = '0';
      iframe.style.bottom = '0';
      iframe.style.width = '0';
      iframe.style.height = '0';
      iframe.style.border = '0';
      iframe.style.visibility = 'hidden';
      iframe.setAttribute('aria-hidden', 'true');
      document.body.appendChild(iframe);

      const doc = iframe.contentWindow.document;

      doc.open();
      doc.write(`
        <!DOCTYPE html>
        <html lang="en">
        <head>
          <meta charset="utf-8" />
          <title>Application Confirmation Slip</title>
          <meta name="viewport" content="width=device-width, initial-scale=1" />
          <base href="${window.location.origin}/">
          <style>
            * { box-sizing: border-box; }
            html, body {
              margin: 0;
              padding: 0;
              background: #ffffff;
              color: #213249;
              font-family: "Segoe UI", Arial, sans-serif;
            }

            body {
              padding: 24px;
            }

            .print-slip{
              position:relative;
              background:#ffffff;
              border:1px solid #b9d0f5;
              border-radius:24px;
              overflow:hidden;
              padding:28px;
            }

            .print-slip::before{
              content: attr(data-watermark);
              position:absolute;
              inset:0;
              display:flex;
              align-items:center;
              justify-content:center;
              font-size:56px;
              line-height:1.15;
              text-align:center;
              color:rgba(31,104,193,.10);
              font-weight:900;
              letter-spacing:.08em;
              transform:rotate(-24deg);
              pointer-events:none;
              padding:30px;
            }

            .print-head{
              display:flex;
              align-items:center;
              justify-content:space-between;
              gap:16px;
              margin-bottom:18px;
              position:relative;
              z-index:1;
            }

            .print-head .left{
              display:flex;
              align-items:center;
              gap:14px;
            }

            .print-head img{
              width:62px;
              height:62px;
              object-fit:contain;
            }

            .print-head h4{
              margin:0;
              font-size:22px;
              color:#174a8a;
              font-weight:900;
            }

            .print-head p{
              margin:4px 0 0;
              color:#44627a;
              font-size:14px;
            }

            .print-badge{
              padding:10px 14px;
              border-radius:999px;
              background:#eef5ff;
              color:#1f68c1;
              font-weight:800;
              border:1px solid #c9dbfb;
              white-space:nowrap;
            }

            .print-body{
              position:relative;
              z-index:1;
              border-top:1px solid #dbe7fb;
              padding-top:18px;
            }

            .print-row{
              display:grid;
              grid-template-columns:220px 1fr;
              gap:12px;
              padding:10px 0;
              border-bottom:1px dashed #dbe7fb;
            }

            .print-row .label{
              color:#5a6c82;
              font-weight:700;
            }

            .print-row .value{
              color:#213249;
              font-weight:800;
              word-break:break-word;
            }

            .print-foot{
              position:relative;
              z-index:1;
              margin-top:16px;
              color:#51657d;
              font-size:14px;
              line-height:1.55;
            }

            @page {
              size: auto;
              margin: 12mm;
            }

            @media print {
              html, body {
                background: #ffffff !important;
              }

              body {
                padding: 0;
              }

              .print-slip {
                border: none;
                box-shadow: none;
              }
            }
          </style>
        </head>
        <body>${printSource.outerHTML}</body>
        </html>
      `);
      doc.close();

      let hasPrinted = false;

      const runPrint = () => {
        if (hasPrinted) return;
        hasPrinted = true;

        try {
          iframe.contentWindow.focus();
          iframe.contentWindow.print();
        } finally {
          setTimeout(() => {
            iframe.remove();
          }, 1500);
        }
      };

      iframe.onload = () => {
        setTimeout(runPrint, 250);
      };

      setTimeout(runPrint, 1000);
    }

    window.closeSuccessModalNow = function (e) {
      if (e) {
        e.preventDefault();
        e.stopPropagation();
      }
      closeSuccessModal();
    };

    window.closeRequirementModalNow = function (e) {
      if (e) {
        e.preventDefault();
        e.stopPropagation();
      }
      closeRequirementModal();
    };

    window.triggerPrintDownloadNow = function (e) {
      if (e) {
        e.preventDefault();
        e.stopPropagation();
      }
      triggerPrintDownload();
    };

    document.querySelectorAll('.btn-view-req').forEach((btn) => {
      btn.onclick = function (e) {
        e.preventDefault();
        e.stopPropagation();
        const index = Number(btn.getAttribute('data-req-index'));
        const item = requirementData[index];
        if (!item) return;
        openRequirementModal(item.title, item.requirement);
      };
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        if (successModal.classList.contains('open')) closeSuccessModal();
        if (requirementModal.classList.contains('open')) closeRequirementModal();
      }
    });
  </script>
</body>
</html>