<%
function money(value) {
  return Number(value || 0).toLocaleString(
    'en-NG',
    {
      minimumFractionDigits: 2,
      maximumFractionDigits: 2
    }
  );
}
%>

<section class="content-header">
  <div class="container-fluid">
    <div class="row mb-2">
      <div class="col-sm-7">
        <h1>
          <i class="fas fa-hand-holding-usd mr-2"></i>
          Pay Acceptance Fee
        </h1>
      </div>

      <div class="col-sm-5">
        <ol class="breadcrumb float-sm-right">
          <li class="breadcrumb-item">
            <a href="/applicant/dashboard">Dashboard</a>
          </li>
          <li class="breadcrumb-item active">
            Acceptance Fee
          </li>
        </ol>
      </div>
    </div>
  </div>
</section>

<section class="content">
  <div class="container-fluid">
    <%
      const errors =
        messages && messages.error
          ? messages.error
          : [];

      const errorList =
        Array.isArray(errors) ? errors : [errors];
    %>

    <% errorList.filter(Boolean).forEach((message) => { %>
      <div class="alert alert-danger">
        <i class="fas fa-exclamation-circle mr-1"></i>
        <%= message %>
      </div>
    <% }) %>

    <div class="card card-outline card-success">
      <div class="card-header">
        <h3 class="card-title">
          My Applications
        </h3>
      </div>

      <div class="card-body p-0">
        <% if (!applications.length) { %>
          <div class="p-5 text-center">
            <i class="fas fa-info-circle fa-3x text-info mb-3"></i>

            <h4>No Application Found</h4>

            <p class="text-muted mb-0">
              You must submit an application before acceptance-fee
              payment can become available.
            </p>
          </div>
        <% } else { %>
          <div class="table-responsive">
            <table class="table table-bordered table-hover mb-0">
              <thead>
                <tr>
                  <th>Application</th>
                  <th>Application Number</th>
                  <th>Application Status</th>
                  <th>Acceptance Charges</th>
                  <th>Acceptance Status</th>
                  <th style="width:270px">Action</th>
                </tr>
              </thead>

              <tbody>
                <% applications.forEach((item) => {
                  const applicationStatus = String(
                    item.application_status || ''
                  ).toUpperCase();

                  const paymentStatus = String(
                    item.acceptance_payment_status || ''
                  ).toUpperCase();

                  const invoiceStatus = String(
                    item.invoice_status || ''
                  ).toUpperCase();

                  const admitted =
                    applicationStatus === 'ADMITTED';

                  const paid =
                    paymentStatus === 'PAID' ||
                    invoiceStatus === 'PAID';

                  const paymentConfigured =
                    Number(item.acceptance_payment_type_id) > 0 &&
                    Number(
                      item.acceptance_payment_type_active
                    ) === 1 &&
                    String(item.acceptance_stid || '').trim();
                %>
                  <tr>
                    <td>
                      <strong>
                        <%= item.application_title %>
                      </strong>

                      <% if (item.category) { %>
                        <div class="small text-muted">
                          <%= item.category %>
                        </div>
                      <% } %>
                    </td>

                    <td>
                      <%= item.application_number || '-' %>
                    </td>

                    <td>
                      <% if (admitted) { %>
                        <span class="badge badge-success">
                          Admitted
                        </span>
                      <% } else if (
                        applicationStatus === 'REJECTED'
                      ) { %>
                        <span class="badge badge-danger">
                          Not Admitted
                        </span>
                      <% } else if (
                        applicationStatus === 'SUBMITTED' ||
                        applicationStatus === 'UNDER_REVIEW'
                      ) { %>
                        <span class="badge badge-info">
                          Under Consideration
                        </span>
                      <% } else { %>
                        <span class="badge badge-secondary">
                          <%= applicationStatus
                            .replaceAll('_', ' ') %>
                        </span>
                      <% } %>
                    </td>

                    <td>
                      ₦<%= money(
                        item.configured_acceptance_total
                      ) %>
                    </td>

                    <td>
                      <% if (paid) { %>
                        <span class="badge badge-success">
                          Paid
                        </span>
                      <% } else if (!admitted) { %>
                        <span class="badge badge-secondary">
                          Not Available
                        </span>
                      <% } else if (item.order_id) { %>
                        <span class="badge badge-warning">
                          Pending
                        </span>
                      <% } else { %>
                        <span class="badge badge-primary">
                          Available
                        </span>
                      <% } %>
                    </td>

                    <td>
                      <% if (!admitted) { %>
                        <div class="text-muted">
                          <i class="fas fa-lock mr-1"></i>
                          You are not eligible for acceptance-fee
                          payment until this application is admitted.
                        </div>
                      <% } else if (paid && item.order_id) { %>
                        <a
                          class="btn btn-success btn-sm"
                          target="_blank"
                          href="/payment/print/<%= encodeURIComponent(
                            item.order_id
                          ) %>?type=receipt&dl=0"
                        >
                          <i class="fas fa-receipt mr-1"></i>
                          View Receipt
                        </a>
                      <% } else if (!paymentConfigured) { %>
                        <div class="text-danger">
                          <i class="fas fa-exclamation-triangle mr-1"></i>
                          Acceptance payment configuration is
                          awaiting completion by the College.
                        </div>
                      <% } else if (item.order_id) { %>
                        <a
                          class="btn btn-warning btn-sm"
                          href="/payment?from=application&order_id=<%= encodeURIComponent(
                            item.order_id
                          ) %>"
                        >
                          <i class="fas fa-credit-card mr-1"></i>
                          Continue Payment
                        </a>
                      <% } else { %>
                        <form
                          method="POST"
                          action="/applicant/payments/acceptance/<%= item.id %>/start"
                          class="d-inline"
                        >
                          <input
                            type="hidden"
                            name="_csrf"
                            value="<%= csrfToken %>"
                          >

                          <button
                            type="submit"
                            class="btn btn-primary btn-sm"
                          >
                            <i class="fas fa-credit-card mr-1"></i>
                            Pay Acceptance Fee
                          </button>
                        </form>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</section>
