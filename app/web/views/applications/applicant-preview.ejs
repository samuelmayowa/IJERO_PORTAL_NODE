<%
const details =
  applicationDetails &&
  typeof applicationDetails === 'object'
    ? applicationDetails
    : {};

const personal =
  details.personal &&
  typeof details.personal === 'object'
    ? details.personal
    : {};

const choice =
  details.programme_choice &&
  typeof details.programme_choice === 'object'
    ? details.programme_choice
    : {};

const applicationType =
  String(
    form.category ||
    details.application_type ||
    ''
  ).toUpperCase();

const applicationTypeLabels = {
  ND: 'ND Application',
  HND: 'HND Application',
  PRELIM: 'Prelim Application',
  UTME: 'UTME/Post-UTME Application'
};

const fullName = [
  personal.first_name,
  personal.middle_name,
  personal.surname
].filter(Boolean).join(' ');

const previewOLevel =
  details.olevel &&
  typeof details.olevel === 'object'
    ? details.olevel
    : {};

const previewOLevelSittings =
  Array.isArray(previewOLevel.sittings)
    ? previewOLevel.sittings.slice(
        0,
        Number(previewOLevel.sitting_count) === 2
          ? 2
          : 1
      )
    : [];

const previewOLevelSubjects = [
  {
    key: 'english_language',
    label: 'English Language'
  },
  {
    key: 'mathematics',
    label: 'Mathematics'
  },
  {
    key: 'biology',
    label: 'Biology'
  },
  {
    key: 'physics',
    label: 'Physics'
  },
  {
    key: 'chemistry',
    label: 'Chemistry'
  },
  {
    key: 'economics',
    label: 'Economics'
  },
  {
    key: 'agricultural_science',
    label: 'Agricultural Science'
  },
  {
    key: 'geography',
    label: 'Geography'
  },
  {
    key: 'civic_education',
    label: 'Civic Education'
  }
];

const previewApplicationDocuments =
  Array.isArray(applicationDocuments)
    ? applicationDocuments
    : [];

const previewApplicationDocumentTypes = [
  'PASSPORT',
  'JAMB_RESULT',
  'OLEVEL_RESULT',
  'BIRTH_CERTIFICATE',
  'LGA_IDENTIFICATION',
  'OTHER'
];

const previewApplicationDocumentLabels = {
  PASSPORT: 'Passport Photograph',
  JAMB_RESULT: 'JAMB Result or Registration Slip',
  OLEVEL_RESULT: "O'Level Result",
  BIRTH_CERTIFICATE:
    'Birth Certificate or Declaration of Age',
  LGA_IDENTIFICATION:
    'LGA or State Identification',
  OTHER: 'Additional Supporting Document'
};


const previewApplicationStatus =
  String(progress.status || '').toUpperCase();

const previewApplicationSubmitted = [
  'SUBMITTED',
  'UNDER_REVIEW',
  'ADMITTED',
  'REJECTED'
].includes(previewApplicationStatus);

%>

<section class="content-header">
  <div class="container-fluid">
    <div class="row mb-2">
      <div class="col-sm-8">
        <h1>
          <i class="fas fa-eye mr-2"></i>
          Application Preview
        </h1>
      </div>

      <div class="col-sm-4">
        <ol class="breadcrumb float-sm-right">
          <li class="breadcrumb-item">
            <a href="/applicant/dashboard">
              Dashboard
            </a>
          </li>
          <li class="breadcrumb-item active">
            Preview
          </li>
        </ol>
      </div>
    </div>
  </div>
</section>

<section class="content">
  <div class="container-fluid">
    <% if (messages && messages.error) { %>
      <div class="alert alert-danger">
        <%= messages.error %>
      </div>
    <% } %>

    <% if (messages && messages.success) { %>
      <div class="alert alert-success">
        <%= messages.success %>
      </div>
    <% } %>

    <div class="alert alert-info">
      Review the information below carefully. Final submission
      will be enabled after the remaining application sections
      are added.
    </div>

    <div class="card card-outline card-success">
      <div class="card-header">
        <h3 class="card-title">
          <i class="fas fa-file-alt mr-1"></i>
          Application Summary
        </h3>
      </div>

      <div class="card-body p-0">
        <table class="table table-bordered mb-0">
          <tbody>
            <tr>
              <th style="width:35%">Application Number</th>
              <td>
                <strong>
                  <%= progress.application_number %>
                </strong>
              </td>
            </tr>
            <tr>
              <th>Application Form</th>
              <td><%= form.title %></td>
            </tr>
            <tr>
              <th>Application Type</th>
              <td>
                <%= applicationTypeLabels[applicationType] ||
                  applicationType ||
                  '-' %>
              </td>
            </tr>
            <tr>
              <th>Academic Session</th>
              <td><%= form.session_name || '-' %></td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <div class="card">
      <div class="card-header">
        <h3 class="card-title">
          <i class="fas fa-user mr-1"></i>
          Personal Information
        </h3>
      </div>

      <div class="card-body p-0">
        <table class="table table-bordered mb-0">
          <tbody>
            <tr>
              <th style="width:35%">Full Name</th>
              <td><%= fullName || '-' %></td>
            </tr>
            <tr>
              <th>Gender</th>
              <td><%= personal.gender || '-' %></td>
            </tr>
            <tr>
              <th>Date of Birth</th>
              <td><%= personal.date_of_birth || '-' %></td>
            </tr>
            <tr>
              <th>Email Address</th>
              <td><%= personal.email || '-' %></td>
            </tr>
            <tr>
              <th>Phone Number</th>
              <td><%= personal.phone || '-' %></td>
            </tr>
            <tr>
              <th>State of Origin</th>
              <td><%= personal.state_of_origin || '-' %></td>
            </tr>
            <tr>
              <th>Local Government Area</th>
              <td><%= personal.lga || '-' %></td>
            </tr>
            <tr>
              <th>Residential Address</th>
              <td>
                <%= personal.residential_address || '-' %>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <% if (applicationType === 'UTME') { %>
      <div class="card">
        <div class="card-header">
          <h3 class="card-title">
            <i class="fas fa-graduation-cap mr-1"></i>
            UTME Information
          </h3>
        </div>

        <div class="card-body p-0">
          <table class="table table-bordered mb-0">
            <tbody>
              <tr>
                <th style="width:35%">
                  JAMB Registration Number
                </th>
                <td>
                  <%= personal.jamb_registration_number ||
                    '-' %>
                </td>
              </tr>
              <tr>
                <th>UTME Total Score</th>
                <td>
                  <%= personal.jamb_total_score || '-' %>
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    <% } %>

    <div class="card">
      <div class="card-header">
        <h3 class="card-title">
          <i class="fas fa-certificate mr-1"></i>
          O'Level Result Information
        </h3>
      </div>

      <div class="card-body">
        <% if (!previewOLevelSittings.length) { %>
          <div class="alert alert-warning mb-0">
            No O'Level result information has been entered.
          </div>
        <% } %>

        <% previewOLevelSittings.forEach(
          (sitting, sittingIndex) => {
            const sittingSubjects =
              sitting.subjects &&
              typeof sitting.subjects === 'object'
                ? sitting.subjects
                : {};
        %>
          <div class="card card-outline card-secondary">
            <div class="card-header">
              <h3 class="card-title">
                <%= sittingIndex === 0
                  ? 'First Sitting'
                  : 'Second Sitting' %>
              </h3>
            </div>

            <div class="card-body p-0">
              <table class="table table-bordered mb-0">
                <tbody>
                  <tr>
                    <th style="width:35%">
                      Examination Type
                    </th>
                    <td>
                      <%= sitting.examination_type || '-' %>
                    </td>
                  </tr>

                  <tr>
                    <th>Examination Number</th>
                    <td>
                      <%= sitting.examination_number || '-' %>
                    </td>
                  </tr>

                  <tr>
                    <th>Examination Year</th>
                    <td>
                      <%= sitting.examination_year || '-' %>
                    </td>
                  </tr>
                </tbody>
              </table>

              <div class="table-responsive">
                <table class="table table-striped table-bordered mb-0">
                  <thead>
                    <tr>
                      <th>Subject</th>
                      <th style="width:25%">Grade</th>
                    </tr>
                  </thead>

                  <tbody>
                    <% previewOLevelSubjects.forEach(
                      (subject) => {
                        const grade =
                          sittingSubjects[subject.key] || '';
                    %>
                      <tr>
                        <td><%= subject.label %></td>
                        <td>
                          <%= grade || 'Not entered' %>
                        </td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    </div>

    <div class="card">
      <div class="card-header">
        <h3 class="card-title">
          <i class="fas fa-paperclip mr-1"></i>
          Uploaded Application Documents
        </h3>
      </div>

      <div class="card-body p-0">
        <% if (!previewApplicationDocuments.length) { %>
          <div class="alert alert-warning m-3">
            No application documents have been uploaded.
          </div>
        <% } else { %>
          <div class="table-responsive">
            <table class="table table-bordered table-striped mb-0">
              <thead>
                <tr>
                  <th>Document</th>
                  <th>Filename</th>
                  <th style="width:140px">Size</th>
                  <th style="width:110px">Action</th>
                </tr>
              </thead>

              <tbody>
                <% previewApplicationDocuments.forEach(
                  (document) => {
                    const documentType =
                      String(
                        document.document_type || ''
                      ).toUpperCase();
                %>
                  <tr>
                    <td>
                      <%= previewApplicationDocumentLabels[
                        documentType
                      ] || document.document_label || documentType %>
                    </td>

                    <td>
                      <%= document.original_filename %>
                    </td>

                    <td>
                      <%= (
                        Number(document.size_bytes || 0)
                        / 1024
                      ).toFixed(1) %> KB
                    </td>

                    <td>
                      <a
                        href="/applicant/applications/<%= progress.id %>/documents/<%= document.id %>/download"
                        class="btn btn-sm btn-outline-primary"
                      >
                        <i class="fas fa-download mr-1"></i>
                        View
                      </a>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>

    <div class="card">
      <div class="card-header">
        <h3 class="card-title">
          <i class="fas fa-university mr-1"></i>
          Course of Study
        </h3>
      </div>

      <div class="card-body p-0">
        <table class="table table-bordered mb-0">
          <tbody>
            <tr>
              <th style="width:35%">School</th>
              <td><%= choice.school_name || '-' %></td>
            </tr>
            <tr>
              <th>Department</th>
              <td><%= choice.department_name || '-' %></td>
            </tr>
            <tr>
              <th>Programme</th>
              <td>
                <strong>
                  <%= choice.programme_name || '-' %>
                </strong>
              </td>
            </tr>
          </tbody>
        </table>
      </div>

      <div class="card-footer">
        <% if (!previewApplicationSubmitted) { %>
          <div class="alert alert-light border">
            <div class="custom-control custom-checkbox">
              <input
                type="checkbox"
                id="applicantDeclaration"
                name="declaration_accepted"
                value="yes"
                class="custom-control-input"
                form="finalSubmissionForm"
                required
              >

              <label
                class="custom-control-label"
                for="applicantDeclaration"
              >
                I confirm that all information and documents
                supplied in this application are complete,
                accurate and genuinely belong to me. I
                understand that false or misleading
                information may result in rejection or
                withdrawal of admission.
              </label>
            </div>
          </div>

          <div class="d-flex flex-wrap align-items-center">
            <a
              href="/applicant/applications/<%= encodeURIComponent(
                form.slug
              ) %>/form"
              class="btn btn-outline-primary mr-2 mb-2"
            >
              <i class="fas fa-arrow-left mr-1"></i>
              Back to Edit
            </a>

            <a
              href="/applicant/applications/<%= progress.id %>/print"
              target="_blank"
              rel="noopener"
              class="btn btn-outline-secondary mr-2 mb-2"
            >
              <i class="fas fa-print mr-1"></i>
              Print Draft
            </a>

            <form
              id="finalSubmissionForm"
              method="post"
              action="/applicant/applications/<%= encodeURIComponent(
                form.slug
              ) %>/submit"
              class="ml-auto mb-2"
              onsubmit="return window.confirm(
                'Submit this application permanently? You will no longer be able to edit the form or replace uploaded documents.'
              );"
            >
              <input
                type="hidden"
                name="_csrf"
                value="<%= typeof csrfToken !== 'undefined'
                  ? csrfToken
                  : '' %>"
              >

              <button
                type="submit"
                class="btn btn-success"
              >
                <i class="fas fa-paper-plane mr-1"></i>
                Final Submit
              </button>
            </form>
          </div>
        <% } else { %>
          <div class="alert alert-success">
            <i class="fas fa-check-circle mr-1"></i>

            This application has been submitted successfully
            and is now read-only.

            <% if (progress.submitted_at) { %>
              <br>

              <small>
                Submitted:
                <%= new Date(
                  progress.submitted_at
                ).toLocaleString('en-GB') %>
              </small>
            <% } %>
          </div>

          <div class="d-flex flex-wrap align-items-center">
            <a
              href="/applicant/applications/<%= progress.id %>/print"
              target="_blank"
              rel="noopener"
              class="btn btn-success mr-2 mb-2"
            >
              <i class="fas fa-print mr-1"></i>
              Print Application
            </a>

            <a
              href="/applicant/dashboard"
              class="btn btn-secondary ml-auto mb-2"
            >
              Return to Dashboard
            </a>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</section>
