<%
  const formatNumber = (value) =>
    Number(value || 0).toLocaleString('en-NG');

  const formatMoney = (value) =>
    Number(value || 0).toLocaleString('en-NG', {
      style: 'currency',
      currency: 'NGN',
      minimumFractionDigits: 2
    });

  const formatDateTime = (value) => {
    if (!value) return '-';

    const date = new Date(value);

    return Number.isNaN(date.getTime())
      ? value
      : date.toLocaleString('en-NG');
  };

  const badgeClass = (status) => {
    const value = String(status || '').toUpperCase();

    if (['PAID', 'ADMITTED', 'SUBMITTED'].includes(value)) {
      return 'badge-success';
    }

    if (['PENDING', 'UNDER_REVIEW', 'IN_PROGRESS'].includes(value)) {
      return 'badge-warning';
    }

    if (['FAILED', 'REJECTED', 'CANCELLED'].includes(value)) {
      return 'badge-danger';
    }

    return 'badge-secondary';
  };

  const queryUrl = (overrides = {}) => {
    const merged = {
      ...filters,
      ...overrides
    };

    return '?' + Object.entries(merged)
      .filter(([key, value]) =>
        key !== 'page' ||
        String(value || '') !== ''
      )
      .filter(([, value]) =>
        String(value ?? '') !== ''
      )
      .map(([key, value]) =>
        encodeURIComponent(key) +
        '=' +
        encodeURIComponent(value)
      )
      .join('&');
  };

  const pageStart =
    pagination.total === 0
      ? 0
      : ((pagination.page - 1) *
          pagination.pageSize) + 1;

  const pageEnd = Math.min(
    pagination.page * pagination.pageSize,
    pagination.total
  );
%>

<section class="content-header">
  <div class="container-fluid">
    <div class="row mb-2">
      <div class="col-sm-7">
        <h1>
          <i class="fas fa-file-alt mr-2"></i>
          Applications Report
        </h1>
      </div>

      <div class="col-sm-5 text-sm-right">
        <a
          href="/staff/admissions/applications/export.csv?<%= exportQuery %>"
          class="btn btn-success"
        >
          <i class="fas fa-file-csv mr-1"></i>
          Export CSV
        </a>
      </div>
    </div>
  </div>
</section>

<section class="content">
  <div class="container-fluid">

    <div class="row">
      <div class="col-lg-3 col-6">
        <div class="small-box bg-info">
          <div class="inner">
            <h3><%= formatNumber(summary.total_started) %></h3>
            <p>Total Applications Started</p>
          </div>
          <div class="icon">
            <i class="fas fa-users"></i>
          </div>
        </div>
      </div>

      <div class="col-lg-3 col-6">
        <div class="small-box bg-warning">
          <div class="inner">
            <h3><%= formatNumber(summary.in_progress) %></h3>
            <p>Started / In Progress</p>
          </div>
          <div class="icon">
            <i class="fas fa-edit"></i>
          </div>
        </div>
      </div>

      <div class="col-lg-3 col-6">
        <div class="small-box bg-primary">
          <div class="inner">
            <h3><%= formatNumber(summary.total_submitted) %></h3>
            <p>Total Submitted</p>
          </div>
          <div class="icon">
            <i class="fas fa-paper-plane"></i>
          </div>
        </div>
      </div>

      <div class="col-lg-3 col-6">
        <div class="small-box bg-success">
          <div class="inner">
            <h3><%= formatNumber(summary.total_admitted) %></h3>
            <p>Total Admitted</p>
          </div>
          <div class="icon">
            <i class="fas fa-user-graduate"></i>
          </div>
        </div>
      </div>

      <div class="col-lg-3 col-6">
        <div class="small-box bg-secondary">
          <div class="inner">
            <h3><%= formatNumber(summary.under_review) %></h3>
            <p>Under Review</p>
          </div>
          <div class="icon">
            <i class="fas fa-search"></i>
          </div>
        </div>
      </div>

      <div class="col-lg-3 col-6">
        <div class="small-box bg-danger">
          <div class="inner">
            <h3><%= formatNumber(summary.total_rejected) %></h3>
            <p>Rejected</p>
          </div>
          <div class="icon">
            <i class="fas fa-user-times"></i>
          </div>
        </div>
      </div>

      <div class="col-lg-3 col-6">
        <div class="small-box bg-teal">
          <div class="inner">
            <h3><%= formatNumber(summary.submitted_today) %></h3>
            <p>Submitted Today</p>
          </div>
          <div class="icon">
            <i class="fas fa-calendar-day"></i>
          </div>
        </div>
      </div>

      <div class="col-lg-3 col-6">
        <div class="small-box bg-indigo">
          <div class="inner">
            <h3><%= formatMoney(summary.application_paid_amount) %></h3>
            <p>
              Application Fees Paid
              (<%= formatNumber(summary.application_paid_count) %>)
            </p>
          </div>
          <div class="icon">
            <i class="fas fa-money-bill-wave"></i>
          </div>
        </div>
      </div>
    </div>

    <div class="card card-outline card-primary">
      <div class="card-header">
        <h3 class="card-title">
          Search and Filters
        </h3>
      </div>

      <div class="card-body">
        <form
          method="GET"
          action="/staff/admissions/applications"
        >
          <div class="row">
            <div class="form-group col-lg-3 col-md-6">
              <label>Academic Session</label>

              <select
                name="session_id"
                class="form-control"
              >
                <% options.sessions.forEach((session) => { %>
                  <option
                    value="<%= session.id %>"
                    <%= Number(filters.session_id) ===
                      Number(session.id)
                        ? 'selected'
                        : '' %>
                  >
                    <%= session.name %>
                    <%= Number(session.is_current) === 1
                      ? '(Current)'
                      : '' %>
                  </option>
                <% }) %>
              </select>
            </div>

            <div class="form-group col-lg-3 col-md-6">
              <label>Application Form</label>

              <select
                name="application_form_id"
                class="form-control"
              >
                <option value="">All Forms</option>

                <% options.forms.forEach((form) => { %>
                  <option
                    value="<%= form.id %>"
                    <%= Number(filters.application_form_id) ===
                      Number(form.id)
                        ? 'selected'
                        : '' %>
                  >
                    <%= form.title %>
                  </option>
                <% }) %>
              </select>
            </div>

            <div class="form-group col-lg-3 col-md-6">
              <label>Programme</label>

              <select
                name="programme"
                class="form-control"
              >
                <option value="">All Programmes</option>

                <% options.programmes.forEach((programme) => { %>
                  <option
                    value="<%= programme.name %>"
                    <%= filters.programme === programme.name
                      ? 'selected'
                      : '' %>
                  >
                    <%= programme.name %>
                  </option>
                <% }) %>
              </select>
            </div>

            <div class="form-group col-lg-3 col-md-6">
              <label>Application Status</label>

              <select
                name="status"
                class="form-control"
              >
                <option value="">All Statuses</option>

                <% [
                  'DRAFT',
                  'AWAITING_PAYMENT',
                  'IN_PROGRESS',
                  'SUBMITTED',
                  'UNDER_REVIEW',
                  'ADMITTED',
                  'REJECTED',
                  'WITHDRAWN'
                ].forEach((status) => { %>
                  <option
                    value="<%= status %>"
                    <%= filters.status === status
                      ? 'selected'
                      : '' %>
                  >
                    <%= status.replace(/_/g, ' ') %>
                  </option>
                <% }) %>
              </select>
            </div>

            <div class="form-group col-lg-3 col-md-6">
              <label>Payment Status</label>

              <select
                name="payment_status"
                class="form-control"
              >
                <option value="">All Payment Statuses</option>

                <% [
                  'NOT_REQUIRED',
                  'UNPAID',
                  'PENDING',
                  'PAID',
                  'FAILED'
                ].forEach((status) => { %>
                  <option
                    value="<%= status %>"
                    <%= filters.payment_status === status
                      ? 'selected'
                      : '' %>
                  >
                    <%= status.replace(/_/g, ' ') %>
                  </option>
                <% }) %>
              </select>
            </div>

            <div class="form-group col-lg-2 col-md-6">
              <label>From Date</label>

              <input
                type="date"
                name="from_date"
                value="<%= filters.from_date %>"
                class="form-control"
              >
            </div>

            <div class="form-group col-lg-2 col-md-6">
              <label>To Date</label>

              <input
                type="date"
                name="to_date"
                value="<%= filters.to_date %>"
                class="form-control"
              >
            </div>

            <div class="form-group col-lg-3 col-md-6">
              <label>Search</label>

              <input
                type="text"
                name="q"
                value="<%= filters.q %>"
                class="form-control"
                placeholder="Name, application no., JAMB, phone, RRR..."
              >
            </div>

            <div class="form-group col-lg-2 col-md-6">
              <label>Rows Per Page</label>

              <select
                name="page_size"
                class="form-control"
              >
                <% [25, 50, 100].forEach((size) => { %>
                  <option
                    value="<%= size %>"
                    <%= Number(filters.page_size) === size
                      ? 'selected'
                      : '' %>
                  >
                    <%= size %>
                  </option>
                <% }) %>
              </select>
            </div>
          </div>

          <button class="btn btn-primary" type="submit">
            <i class="fas fa-search mr-1"></i>
            Apply Filters
          </button>

          <a
            href="/staff/admissions/applications"
            class="btn btn-default"
          >
            Reset
          </a>
        </form>
      </div>
    </div>

    <div class="row">
      <div class="col-lg-8">
        <div class="card">
          <div class="card-header">
            <h3 class="card-title">
              Application Records
            </h3>

            <div class="card-tools">
              Showing <%= pageStart %>–<%= pageEnd %>
              of <%= formatNumber(pagination.total) %>
            </div>
          </div>

          <div class="card-body p-0">
            <div class="table-responsive">
              <table class="table table-striped table-bordered mb-0">
                <thead>
                  <tr>
                    <th>Application</th>
                    <th>Applicant</th>
                    <th>JAMB / UTME</th>
                    <th>Programme</th>
                    <th>Status</th>
                    <th>Application Fee</th>
                    <th>Submitted</th>
                  </tr>
                </thead>

                <tbody>
                  <% if (!rows.length) { %>
                    <tr>
                      <td
                        colspan="7"
                        class="text-center text-muted py-4"
                      >
                        No application matched the selected filters.
                      </td>
                    </tr>
                  <% } %>

                  <% rows.forEach((row) => { %>
                    <tr>
                      <td>
                        <strong>
                          <%= row.application_number %>
                        </strong>

                        <br>

                        <small>
                          <%= row.application_title %>
                          <br>
                          <%= row.session_name %>
                        </small>
                      </td>

                      <td>
                        <strong>
                          <%= row.applicant_name %>
                        </strong>

                        <br>

                        <small>
                          <%= row.username %>
                          <br>
                          <%= row.phone %>
                        </small>
                      </td>

                      <td>
                        <%= row.jamb_registration_number || '-' %>

                        <br>

                        <small>
                          Score:
                          <%= row.jamb_total_score || '-' %>
                        </small>
                      </td>

                      <td>
                        <%= row.programme_name || '-' %>
                      </td>

                      <td>
                        <span
                          class="badge <%= badgeClass(
                            row.application_status
                          ) %>"
                        >
                          <%= String(
                            row.application_status || ''
                          ).replace(/_/g, ' ') %>
                        </span>
                      </td>

                      <td>
                        <span
                          class="badge <%= badgeClass(
                            row.application_payment_status
                          ) %>"
                        >
                          <%= String(
                            row.application_payment_status || ''
                          ).replace(/_/g, ' ') %>
                        </span>

                        <% if (row.rrr) { %>
                          <br>
                          <small>RRR: <%= row.rrr %></small>
                        <% } %>
                      </td>

                      <td>
                        <%= formatDateTime(
                          row.submitted_at ||
                          row.created_at
                        ) %>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>

          <% if (pagination.totalPages > 1) { %>
            <div class="card-footer clearfix">
              <ul class="pagination pagination-sm m-0 float-right">
                <li
                  class="page-item <%= pagination.page <= 1
                    ? 'disabled'
                    : '' %>"
                >
                  <a
                    class="page-link"
                    href="<%= queryUrl({
                      page: pagination.page - 1
                    }) %>"
                  >
                    Previous
                  </a>
                </li>

                <%
                  const firstPage = Math.max(
                    1,
                    pagination.page - 2
                  );

                  const lastPage = Math.min(
                    pagination.totalPages,
                    pagination.page + 2
                  );
                %>

                <% for (
                  let pageNumber = firstPage;
                  pageNumber <= lastPage;
                  pageNumber += 1
                ) { %>
                  <li
                    class="page-item <%= pageNumber ===
                      pagination.page
                        ? 'active'
                        : '' %>"
                  >
                    <a
                      class="page-link"
                      href="<%= queryUrl({
                        page: pageNumber
                      }) %>"
                    >
                      <%= pageNumber %>
                    </a>
                  </li>
                <% } %>

                <li
                  class="page-item <%= pagination.page >=
                    pagination.totalPages
                      ? 'disabled'
                      : '' %>"
                >
                  <a
                    class="page-link"
                    href="<%= queryUrl({
                      page: pagination.page + 1
                    }) %>"
                  >
                    Next
                  </a>
                </li>
              </ul>
            </div>
          <% } %>
        </div>
      </div>

      <div class="col-lg-4">
        <div class="card card-outline card-info">
          <div class="card-header">
            <h3 class="card-title">
              Submitted Applications by Day
            </h3>

            <div class="card-tools">
              Last 30 Days
            </div>
          </div>

          <div class="card-body p-0">
            <div class="table-responsive">
              <table class="table table-sm table-striped mb-0">
                <thead>
                  <tr>
                    <th>Date</th>
                    <th class="text-right">
                      Submitted
                    </th>
                  </tr>
                </thead>

                <tbody>
                  <% if (!dailySubmitted.length) { %>
                    <tr>
                      <td
                        colspan="2"
                        class="text-center text-muted py-3"
                      >
                        No submitted application within the last 30 days.
                      </td>
                    </tr>
                  <% } %>

                  <% dailySubmitted.forEach((item) => { %>
                    <tr>
                      <td>
                        <%= new Date(
                          item.activity_date
                        ).toLocaleDateString('en-NG') %>
                      </td>

                      <td class="text-right">
                        <strong>
                          <%= formatNumber(
                            item.total_submitted
                          ) %>
                        </strong>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>

                <tfoot>
                  <tr>
                    <th>Submitted Today</th>
                    <th class="text-right">
                      <%= formatNumber(
                        summary.submitted_today
                      ) %>
                    </th>
                  </tr>
                </tfoot>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>
