
  <section class="content-header">
    <div class="container-fluid">
      <h1>Payment History</h1>
    </div>
  </section>

  <section class="content">
    <div class="container-fluid">

      <div class="card card-outline card-primary">
        <div class="card-header">
          <h3 class="card-title m-0">Validate RRR / Reprint</h3>
        </div>
        <div class="card-body">
          <form method="GET" action="/payment/reprint" class="form-inline" style="gap:10px; display:flex; flex-wrap:wrap;">
            <input
              type="text"
              name="rrr"
              class="form-control"
              placeholder="Enter RRR Number"
              style="min-width:260px;"
            >
            <button type="submit" class="btn btn-primary">
              Validate / Reprint
            </button>
          </form>
          <small class="text-muted d-block mt-2">
            You can enter an RRR here to continue to the reprint / validation page.
          </small>
        </div>
      </div>

      <div class="card card-outline card-success">
        <div class="card-header">
          <h3 class="card-title m-0">All Payment Attempts</h3>
        </div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-striped table-hover mb-0">
              <thead>
                <tr>
                    <th style="width:50px;">#</th>
                    <th style="width:160px;">RRR</th>
                    <th>Purpose</th>
                    <th style="width:120px;">Amount</th>
                    <th style="width:130px;">Portal Charge</th>
                    <th style="width:110px;">Status</th>
                    <th style="width:180px;">Date</th>
                    <th style="width:170px;">Action</th>
                </tr>
                </thead>
              <tbody>
                <% if (!payments || !payments.length) { %>
                  <tr>
                    <td colspan="8" class="text-muted p-3">No payment history found.</td>
                  </tr>
                <% } else { payments.forEach(function(p, i){ %>
                  <tr>
                    <td><%= i + 1 %></td>
                    <td><%= p.rrr || '-' %></td>
                    <td><%= p.purpose || '-' %></td>
                    <td><%= Number(p.amount || 0).toLocaleString() %></td>
                    <td><%= Number(p.portal_charge || 0).toLocaleString() %></td>
                    <td>
                        <span class="badge <%= p.status === 'PAID' ? 'badge-success' : 'badge-secondary' %>">
                        <%= p.status || 'PENDING' %>
                        </span>
                    </td>
                    <td><%= p.date || '-' %></td>
                    <td>
                        <% if (p.order_id) { %>
                        <a
                            href="/payment/print/<%= encodeURIComponent(p.order_id) %>?type=<%= (p.status === 'PAID' ? 'receipt' : 'invoice') %>&dl=0"
                            target="_blank"
                            rel="noopener"
                            class="btn btn-sm <%= p.status === 'PAID' ? 'btn-outline-primary' : 'btn-warning' %>"
                        >
                            <%= p.status === 'PAID' ? 'Print Receipt' : 'Print Invoice' %>
                        </a>
                        <% } else { %>
                        <span class="text-muted">-</span>
                        <% } %>
                    </td>
                    </tr>
                <% }) } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

    </div>
  </section>
</div>