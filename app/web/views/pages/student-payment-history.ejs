<%
const paymentRows = Array.isArray(payments) ? payments : [];

function money(value) {
  return Number(value || 0).toLocaleString(
    "en-NG",
    {
      minimumFractionDigits: 2,
      maximumFractionDigits: 2,
    },
  );
}

function dateTime(value) {
  if (!value) return "-";

  return new Date(value).toLocaleString(
    "en-GB",
    {
      dateStyle: "medium",
      timeStyle: "short",
    },
  );
}

function paymentStatus(payment) {
  return String(
    payment.status ||
    payment.invoice_status ||
    "PENDING",
  ).toUpperCase();
}

const paidPayments = paymentRows.filter(
  (payment) => paymentStatus(payment) === "PAID",
);

const pendingPayments = paymentRows.filter(
  (payment) => paymentStatus(payment) !== "PAID",
);

const totalPaid = paidPayments.reduce(
  (sum, payment) =>
    sum +
    Number(payment.amount || 0) +
    Number(payment.portal_charge || 0),
  0,
);

const CSRF =
  typeof csrfToken !== "undefined"
    ? csrfToken
    : "";
%>

<style>
  .payment-action-group {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .payment-action-group .btn {
    white-space: nowrap;
  }

  .payment-table th {
    background: #f4f6f9;
    vertical-align: middle;
  }

  .payment-table td {
    vertical-align: middle;
  }

  .rrr-code {
    font-family: monospace;
    font-weight: 700;
    letter-spacing: 0.3px;
  }

  .validation-card .form-control {
    min-height: 42px;
  }

  .validation-card .btn {
    min-height: 42px;
  }

  .small-box .inner h3 {
    font-size: 25px;
  }

  @media (max-width: 767px) {
    .payment-action-group {
      min-width: 210px;
    }
  }
</style>

<div class="card card-success validation-card">
  <div class="card-header">
    <h3 class="card-title">
      <i class="fas fa-search-dollar mr-2"></i>
      Validate RRR / Requery Payment
    </h3>
  </div>

  <div class="card-body">
    <div class="alert alert-info">
      Enter an RRR below or use the
      <strong>Requery Payment</strong>
      button beside a pending payment.
      A receipt will only be produced when Remita confirms the payment.
    </div>

    <div class="form-row">
      <div class="form-group col-md-8 mb-md-0">
        <label for="manualRrr">Remita Retrieval Reference (RRR)</label>

        <input
          id="manualRrr"
          class="form-control"
          placeholder="Enter RRR number"
          autocomplete="off"
        >
      </div>

      <div class="form-group col-md-4 mb-0 d-flex align-items-end">
        <button
          id="manualRequeryButton"
          type="button"
          class="btn btn-success btn-block"
        >
          <i class="fas fa-sync-alt mr-1"></i>
          Requery RRR
        </button>
      </div>
    </div>
  </div>
</div>

<div class="row">
  <div class="col-lg-3 col-6">
    <div class="small-box bg-info">
      <div class="inner">
        <h3><%= paymentRows.length %></h3>
        <p>Total Payment Attempts</p>
      </div>

      <div class="icon">
        <i class="fas fa-receipt"></i>
      </div>
    </div>
  </div>

  <div class="col-lg-3 col-6">
    <div class="small-box bg-success">
      <div class="inner">
        <h3><%= paidPayments.length %></h3>
        <p>Confirmed Payments</p>
      </div>

      <div class="icon">
        <i class="fas fa-check-circle"></i>
      </div>
    </div>
  </div>

  <div class="col-lg-3 col-6">
    <div class="small-box bg-warning">
      <div class="inner">
        <h3><%= pendingPayments.length %></h3>
        <p>Pending / Unconfirmed</p>
      </div>

      <div class="icon">
        <i class="fas fa-clock"></i>
      </div>
    </div>
  </div>

  <div class="col-lg-3 col-6">
    <div class="small-box bg-primary">
      <div class="inner">
        <h3>₦<%= money(totalPaid) %></h3>
        <p>Total Confirmed Paid</p>
      </div>

      <div class="icon">
        <i class="fas fa-wallet"></i>
      </div>
    </div>
  </div>
</div>

<div class="card card-outline card-success">
  <div class="card-header">
    <h3 class="card-title">
      <i class="fas fa-history mr-2"></i>
      All Payment Attempts
    </h3>
  </div>

  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-bordered table-striped table-hover mb-0 payment-table">
        <thead>
          <tr>
            <th style="width:55px">#</th>
            <th>RRR</th>
            <th>Purpose</th>
            <th>Type</th>
            <th class="text-right">Amount</th>
            <th>Status</th>
            <th>Date</th>
            <th style="min-width:230px">Action</th>
          </tr>
        </thead>

        <tbody>
          <% if (!paymentRows.length) { %>
            <tr>
              <td colspan="8" class="text-center text-muted p-4">
                No payment attempt was found.
              </td>
            </tr>
          <% } %>

          <% paymentRows.forEach((payment, index) => {
            const status = paymentStatus(payment);

            const purpose =
              payment.payment_type_purpose ||
              payment.purpose ||
              payment.payment_type_name ||
              "Payment";

            const type =
              payment.payment_type_name ||
              payment.type ||
              "Payment";

            const totalAmount =
              Number(payment.amount || 0) +
              Number(payment.portal_charge || 0);

            const reference =
              payment.rrr ||
              payment.order_id ||
              "";

            const encodedOrderId =
              encodeURIComponent(
                payment.order_id || "",
              );
          %>
            <tr>
              <td><%= index + 1 %></td>

              <td>
                <span class="rrr-code">
                  <%= payment.rrr || "-" %>
                </span>

                <% if (payment.order_id) { %>
                  <div class="small text-muted">
                    Order: <%= payment.order_id %>
                  </div>
                <% } %>
              </td>

              <td><%= purpose %></td>

              <td><%= type %></td>

              <td class="text-right">
                ₦<%= money(totalAmount) %>
              </td>

              <td>
                <% if (status === "PAID") { %>
                  <span class="badge badge-success">
                    PAID
                  </span>
                <% } else if (status === "FAILED") { %>
                  <span class="badge badge-danger">
                    FAILED
                  </span>
                <% } else { %>
                  <span class="badge badge-warning">
                    <%= status %>
                  </span>
                <% } %>
              </td>

              <td>
                <%= dateTime(
                  payment.paid_at ||
                  payment.created_at
                ) %>
              </td>

              <td>
                <div class="payment-action-group">
                  <% if (
                    status === "PAID" &&
                    payment.order_id
                  ) { %>
                    <a
                      class="btn btn-success btn-sm"
                      target="_blank"
                      rel="noopener"
                      href="/payment/print/<%= encodedOrderId %>?type=receipt&dl=0"
                    >
                      <i class="fas fa-print mr-1"></i>
                      Print Receipt
                    </a>
                  <% } else { %>
                    <button
                      type="button"
                      class="btn btn-warning btn-sm js-requery-payment"
                      data-reference="<%= reference %>"
                      data-order-id="<%= payment.order_id || '' %>"
                    >
                      <i class="fas fa-sync-alt mr-1"></i>
                      Requery Payment
                    </button>

                    <% if (payment.order_id) { %>
                      <a
                        class="btn btn-outline-danger btn-sm"
                        target="_blank"
                        rel="noopener"
                        href="/payment/print/<%= encodedOrderId %>?type=unconfirmed&dl=0"
                      >
                        <i class="fas fa-file-pdf mr-1"></i>
                        Unconfirmed Slip
                      </a>
                    <% } %>
                  <% } %>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<script>
  (function () {
    const csrfToken = <%- JSON.stringify(CSRF) %>;

    async function requeryPayment(
      reference,
      button,
    ) {
      const cleanReference = String(
        reference || "",
      ).trim();

      if (!cleanReference) {
        alert("Enter or select a valid RRR.");
        return;
      }

      const originalHtml = button
        ? button.innerHTML
        : "";

      if (button) {
        button.disabled = true;
        button.innerHTML =
          '<i class="fas fa-spinner fa-spin mr-1"></i> Checking Remita...';
      }

      try {
        const response = await fetch(
          "/payment/reprint",
          {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
              "Accept": "application/json",
              "CSRF-Token": csrfToken,
            },
            body: JSON.stringify({
              rrr: cleanReference,
              studentHistory: "1",
              _csrf: csrfToken,
            }),
          },
        );

        const result = await response.json();

        if (!response.ok || !result.ok) {
          throw new Error(
            result.error ||
            "Payment requery failed.",
          );
        }

        if (result.kind === "receipt") {
          alert(
            "Payment confirmed successfully. The receipt will now open.",
          );

          window.open(
            result.viewUrl,
            "_blank",
            "noopener",
          );

          window.setTimeout(
            function () {
              window.location.reload();
            },
            600,
          );

          return;
        }

        alert(
          "Remita did not confirm this payment. An Unconfirmed Payment Slip will now open for Bursary validation.",
        );

        window.open(
          result.viewUrl,
          "_blank",
          "noopener",
        );
      } catch (error) {
        alert(
          error.message ||
          "Payment requery failed.",
        );
      } finally {
        if (button) {
          button.disabled = false;
          button.innerHTML = originalHtml;
        }
      }
    }

    document
      .querySelectorAll(".js-requery-payment")
      .forEach(function (button) {
        button.addEventListener(
          "click",
          function () {
            requeryPayment(
              button.dataset.reference,
              button,
            );
          },
        );
      });

    const manualButton =
      document.getElementById(
        "manualRequeryButton",
      );

    const manualInput =
      document.getElementById(
        "manualRrr",
      );

    manualButton?.addEventListener(
      "click",
      function () {
        requeryPayment(
          manualInput?.value,
          manualButton,
        );
      },
    );

    manualInput?.addEventListener(
      "keydown",
      function (event) {
        if (event.key === "Enter") {
          event.preventDefault();

          requeryPayment(
            manualInput.value,
            manualButton,
          );
        }
      },
    );
  })();
</script>
