<%
  const formatNumber = (value) =>
    Number(value || 0).toLocaleString('en-NG');

  const formatMoney = (value) =>
    Number(value || 0).toLocaleString('en-NG', {
      style: 'currency',
      currency: 'NGN',
      minimumFractionDigits: 2
    });

  const formatDateTime = (value) => {
    if (!value) return '-';

    const date = new Date(value);

    return Number.isNaN(date.getTime())
      ? value
      : date.toLocaleString('en-NG');
  };

  const badgeClass = (status) => {
    const value = String(status || '').toUpperCase();

    if (value === 'PAID') {
      return 'badge-success';
    }

    if (value === 'PENDING') {
      return 'badge-warning';
    }

    if (
      value === 'FAILED' ||
      value === 'CANCELLED'
    ) {
      return 'badge-danger';
    }

    return 'badge-secondary';
  };

  const queryUrl = (overrides = {}) => {
    const merged = {
      ...filters,
      ...overrides
    };

    return '?' + Object.entries(merged)
      .filter(([, value]) =>
        String(value ?? '') !== ''
      )
      .map(([key, value]) =>
        encodeURIComponent(key) +
        '=' +
        encodeURIComponent(value)
      )
      .join('&');
  };

  const pageStart =
    pagination.total === 0
      ? 0
      : ((pagination.page - 1) *
          pagination.pageSize) + 1;

  const pageEnd = Math.min(
    pagination.page * pagination.pageSize,
    pagination.total
  );
%>

<section class="content-header">
  <div class="container-fluid">
    <div class="row mb-2">
      <div class="col-sm-7">
        <h1>
          <i class="fas fa-money-check-alt mr-2"></i>
          <%= config.title %>
        </h1>
      </div>

      <div class="col-sm-5 text-sm-right">
        <a
          href="<%= config.exportPath %>?<%= exportQuery %>"
          class="btn btn-success"
        >
          <i class="fas fa-file-csv mr-1"></i>
          Export CSV
        </a>
      </div>
    </div>
  </div>
</section>

<section class="content">
  <div class="container-fluid">

    <div class="mb-3">
      <a
        href="/staff/fees/application-fees"
        class="btn <%= config.stage === 'APPLICATION' ? 'btn-primary' : 'btn-outline-primary' %>"
      >
        Application Fees
      </a>

      <a
        href="/staff/fees/acceptance-fees"
        class="btn <%= config.stage === 'ACCEPTANCE' ? 'btn-primary' : 'btn-outline-primary' %>"
      >
        Acceptance Fees
      </a>
    </div>

    <div class="row">
      <div class="col-lg-3 col-6">
        <div class="small-box bg-info">
          <div class="inner">
            <h3><%= formatNumber(summary.total_records) %></h3>
            <p>Total Records</p>
          </div>
          <div class="icon">
            <i class="fas fa-list"></i>
          </div>
        </div>
      </div>

      <div class="col-lg-3 col-6">
        <div class="small-box bg-success">
          <div class="inner">
            <h3><%= formatNumber(summary.successful_payments) %></h3>
            <p>Successful Payments</p>
          </div>
          <div class="icon">
            <i class="fas fa-check-circle"></i>
          </div>
        </div>
      </div>

      <div class="col-lg-3 col-6">
        <div class="small-box bg-indigo">
          <div class="inner">
            <h3><%= formatMoney(summary.successful_amount) %></h3>
            <p>Total Successfully Paid</p>
          </div>
          <div class="icon">
            <i class="fas fa-money-bill-wave"></i>
          </div>
        </div>
      </div>

      <div class="col-lg-3 col-6">
        <div class="small-box bg-warning">
          <div class="inner">
            <h3><%= formatNumber(summary.pending_payments) %></h3>
            <p>Pending Payments</p>
          </div>
          <div class="icon">
            <i class="fas fa-clock"></i>
          </div>
        </div>
      </div>

      <div class="col-lg-3 col-6">
        <div class="small-box bg-secondary">
          <div class="inner">
            <h3><%= formatNumber(summary.unpaid_payments) %></h3>
            <p>Unpaid / Not Available</p>
          </div>
          <div class="icon">
            <i class="fas fa-wallet"></i>
          </div>
        </div>
      </div>

      <div class="col-lg-3 col-6">
        <div class="small-box bg-danger">
          <div class="inner">
            <h3><%= formatNumber(summary.failed_payments) %></h3>
            <p>Failed / Cancelled</p>
          </div>
          <div class="icon">
            <i class="fas fa-times-circle"></i>
          </div>
        </div>
      </div>

      <div class="col-lg-3 col-6">
        <div class="small-box bg-teal">
          <div class="inner">
            <h3><%= formatNumber(summary.paid_today) %></h3>
            <p>Successful Payments Today</p>
          </div>
          <div class="icon">
            <i class="fas fa-calendar-day"></i>
          </div>
        </div>
      </div>

      <div class="col-lg-3 col-6">
        <div class="small-box bg-primary">
          <div class="inner">
            <h3><%= formatMoney(summary.amount_paid_today) %></h3>
            <p>Successfully Paid Today</p>
          </div>
          <div class="icon">
            <i class="fas fa-coins"></i>
          </div>
        </div>
      </div>
    </div>

    <div class="card card-outline card-primary">
      <div class="card-header">
        <h3 class="card-title">
          Search and Filters
        </h3>
      </div>

      <div class="card-body">
        <form method="GET" action="<%= config.basePath %>">
          <div class="row">
            <div class="form-group col-lg-3 col-md-6">
              <label>Academic Session</label>

              <select
                name="session_id"
                class="form-control"
              >
                <% options.sessions.forEach((session) => { %>
                  <option
                    value="<%= session.id %>"
                    <%= Number(filters.session_id) === Number(session.id) ? 'selected' : '' %>
                  >
                    <%= session.name %>
                    <%= Number(session.is_current) === 1 ? '(Current)' : '' %>
                  </option>
                <% }) %>
              </select>
            </div>

            <div class="form-group col-lg-3 col-md-6">
              <label>Application Form</label>

              <select
                name="application_form_id"
                class="form-control"
              >
                <option value="">All Forms</option>

                <% options.forms.forEach((form) => { %>
                  <option
                    value="<%= form.id %>"
                    <%= Number(filters.application_form_id) === Number(form.id) ? 'selected' : '' %>
                  >
                    <%= form.title %>
                  </option>
                <% }) %>
              </select>
            </div>

            <div class="form-group col-lg-3 col-md-6">
              <label>Programme</label>

              <select
                name="programme"
                class="form-control"
              >
                <option value="">All Programmes</option>

                <% options.programmes.forEach((programme) => { %>
                  <option
                    value="<%= programme.name %>"
                    <%= filters.programme === programme.name ? 'selected' : '' %>
                  >
                    <%= programme.name %>
                  </option>
                <% }) %>
              </select>
            </div>

            <div class="form-group col-lg-3 col-md-6">
              <label>Payment Status</label>

              <select
                name="payment_status"
                class="form-control"
              >
                <option value="">All Payment Statuses</option>

                <% [
                  'NOT_REQUIRED',
                  'NOT_AVAILABLE',
                  'UNPAID',
                  'PENDING',
                  'PAID',
                  'FAILED',
                  'CANCELLED'
                ].forEach((status) => { %>
                  <option
                    value="<%= status %>"
                    <%= filters.payment_status === status ? 'selected' : '' %>
                  >
                    <%= status.replace(/_/g, ' ') %>
                  </option>
                <% }) %>
              </select>
            </div>

            <div class="form-group col-lg-2 col-md-6">
              <label>From Date</label>

              <input
                type="date"
                name="from_date"
                value="<%= filters.from_date %>"
                class="form-control"
              >
            </div>

            <div class="form-group col-lg-2 col-md-6">
              <label>To Date</label>

              <input
                type="date"
                name="to_date"
                value="<%= filters.to_date %>"
                class="form-control"
              >
            </div>

            <div class="form-group col-lg-4 col-md-6">
              <label>Search</label>

              <input
                type="text"
                name="q"
                value="<%= filters.q %>"
                class="form-control"
                placeholder="Name, application no., phone, RRR, order ID..."
              >
            </div>

            <div class="form-group col-lg-2 col-md-6">
              <label>Rows Per Page</label>

              <select
                name="page_size"
                class="form-control"
              >
                <% [25, 50, 100].forEach((size) => { %>
                  <option
                    value="<%= size %>"
                    <%= Number(filters.page_size) === size ? 'selected' : '' %>
                  >
                    <%= size %>
                  </option>
                <% }) %>
              </select>
            </div>
          </div>

          <button class="btn btn-primary" type="submit">
            <i class="fas fa-search mr-1"></i>
            Apply Filters
          </button>

          <a
            href="<%= config.basePath %>"
            class="btn btn-default"
          >
            Reset
          </a>
        </form>
      </div>
    </div>

    <div class="row">
      <div class="col-lg-8">
        <div class="card">
          <div class="card-header">
            <h3 class="card-title">
              Payment Records
            </h3>

            <div class="card-tools">
              Showing <%= pageStart %>–<%= pageEnd %>
              of <%= formatNumber(pagination.total) %>
            </div>
          </div>

          <div class="card-body p-0">
            <div class="table-responsive">
              <table class="table table-striped table-bordered mb-0">
                <thead>
                  <tr>
                    <th>Application</th>
                    <th>Applicant</th>
                    <th>Programme</th>
                    <th>Status</th>
                    <th>RRR / Order ID</th>
                    <th>Amount</th>
                    <th>Paid Date</th>
                  </tr>
                </thead>

                <tbody>
                  <% if (!rows.length) { %>
                    <tr>
                      <td
                        colspan="7"
                        class="text-center text-muted py-4"
                      >
                        No payment record matched the selected filters.
                      </td>
                    </tr>
                  <% } %>

                  <% rows.forEach((row) => { %>
                    <tr>
                      <td>
                        <strong>
                          <%= row.application_number %>
                        </strong>

                        <br>

                        <small>
                          <%= row.application_title %>
                          <br>
                          <%= row.session_name %>
                        </small>
                      </td>

                      <td>
                        <strong>
                          <%= row.applicant_name %>
                        </strong>

                        <br>

                        <small>
                          <%= row.username %>
                          <br>
                          <%= row.phone %>
                        </small>
                      </td>

                      <td>
                        <%= row.programme_name || '-' %>
                      </td>

                      <td>
                        <span
                          class="badge <%= badgeClass(row.payment_status) %>"
                        >
                          <%= String(row.payment_status || config.emptyStatusLabel).replace(/_/g, ' ') %>
                        </span>

                        <br>

                        <small>
                          Application:
                          <%= String(row.application_status || '').replace(/_/g, ' ') %>
                        </small>
                      </td>

                      <td>
                        <%= row.rrr || '-' %>

                        <br>

                        <small>
                          <%= row.order_id || '-' %>
                        </small>
                      </td>

                      <td>
                        <%= row.invoice_status === 'PAID'
                          ? formatMoney(
                              Number(row.amount || 0) +
                              Number(row.portal_charge || 0)
                            )
                          : '-' %>

                        <% if (row.method) { %>
                          <br>
                          <small><%= row.method %></small>
                        <% } %>
                      </td>

                      <td>
                        <%= formatDateTime(row.paid_at) %>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>

          <% if (pagination.totalPages > 1) { %>
            <div class="card-footer clearfix">
              <ul class="pagination pagination-sm m-0 float-right">
                <li class="page-item <%= pagination.page <= 1 ? 'disabled' : '' %>">
                  <a
                    class="page-link"
                    href="<%= queryUrl({
                      page: pagination.page - 1
                    }) %>"
                  >
                    Previous
                  </a>
                </li>

                <%
                  const firstPage = Math.max(
                    1,
                    pagination.page - 2
                  );

                  const lastPage = Math.min(
                    pagination.totalPages,
                    pagination.page + 2
                  );
                %>

                <% for (
                  let pageNumber = firstPage;
                  pageNumber <= lastPage;
                  pageNumber += 1
                ) { %>
                  <li class="page-item <%= pageNumber === pagination.page ? 'active' : '' %>">
                    <a
                      class="page-link"
                      href="<%= queryUrl({
                        page: pageNumber
                      }) %>"
                    >
                      <%= pageNumber %>
                    </a>
                  </li>
                <% } %>

                <li class="page-item <%= pagination.page >= pagination.totalPages ? 'disabled' : '' %>">
                  <a
                    class="page-link"
                    href="<%= queryUrl({
                      page: pagination.page + 1
                    }) %>"
                  >
                    Next
                  </a>
                </li>
              </ul>
            </div>
          <% } %>
        </div>
      </div>

      <div class="col-lg-4">
        <div class="card card-outline card-success">
          <div class="card-header">
            <h3 class="card-title">
              Successful Payments by Day
            </h3>

            <div class="card-tools">
              Last 30 Days
            </div>
          </div>

          <div class="card-body p-0">
            <div class="table-responsive">
              <table class="table table-sm table-striped mb-0">
                <thead>
                  <tr>
                    <th>Date</th>
                    <th class="text-right">Count</th>
                    <th class="text-right">Amount</th>
                  </tr>
                </thead>

                <tbody>
                  <% if (!dailySuccessful.length) { %>
                    <tr>
                      <td
                        colspan="3"
                        class="text-center text-muted py-3"
                      >
                        No successful payment within the last 30 days.
                      </td>
                    </tr>
                  <% } %>

                  <% dailySuccessful.forEach((item) => { %>
                    <tr>
                      <td>
                        <%= new Date(item.activity_date).toLocaleDateString('en-NG') %>
                      </td>

                      <td class="text-right">
                        <strong>
                          <%= formatNumber(item.successful_payments) %>
                        </strong>
                      </td>

                      <td class="text-right">
                        <%= formatMoney(item.successful_amount) %>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>

                <tfoot>
                  <tr>
                    <th>Today</th>
                    <th class="text-right">
                      <%= formatNumber(summary.paid_today) %>
                    </th>
                    <th class="text-right">
                      <%= formatMoney(summary.amount_paid_today) %>
                    </th>
                  </tr>
                </tfoot>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>
