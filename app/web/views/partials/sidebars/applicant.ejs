<%
// safe currentPath
const path = (typeof currentPath !== 'undefined' && currentPath) ? currentPath : '';
%>
<nav class="mt-2">
  <ul class="nav nav-pills nav-sidebar flex-column" data-widget="treeview" role="menu" data-accordion="false">

    <li class="nav-item">
      <a href="/applicant/dashboard" class="nav-link <%= path === '/applicant/dashboard' ? 'active' : '' %>">
        <i class="nav-icon fas fa-tachometer-alt"></i><p>Dashboard</p>
      </a>
    </li>

    <%
      const openApplicationForms =
        typeof availableApplicationForms !== 'undefined' &&
        Array.isArray(availableApplicationForms)
          ? availableApplicationForms
          : [];

      const inApplicationSection =
        path.startsWith('/applicant/applications');
    %>

    <li class="nav-item has-treeview <%= inApplicationSection ? 'menu-open' : '' %>">
      <a href="#" class="nav-link <%= inApplicationSection ? 'active' : '' %>">
        <i class="nav-icon fas fa-user-plus"></i>
        <p>
          Apply for Admission
          <i class="right fas fa-angle-left"></i>
        </p>
      </a>

      <ul class="nav nav-treeview">
        <% if (!openApplicationForms.length) { %>
          <li class="nav-item">
            <a href="#" class="nav-link disabled">
              <i class="far fa-circle nav-icon"></i>
              <p>No Open Applications</p>
            </a>
          </li>
        <% } %>

        <% openApplicationForms.forEach((applicationForm) => { %>
          <% const applicationUrl =
            '/applicant/applications/' +
            encodeURIComponent(applicationForm.slug); %>

          <li class="nav-item">
            <a
              href="<%= applicationUrl %>"
              class="nav-link <%= path === applicationUrl ? 'active' : '' %>"
            >
              <i class="far fa-circle nav-icon"></i>
              <p><%= applicationForm.title %></p>
            </a>
          </li>
        <% }) %>
      </ul>
    </li>

    <li class="nav-item"><a href="/applicant/payments/acceptance" class="nav-link <%= path.startsWith('/applicant/payments/acceptance') ? 'active' : '' %>"><i class="nav-icon fas fa-hand-holding-usd"></i><p>Pay Acceptance Fee</p></a></li>
    <li class="nav-item"><a href="/payment" class="nav-link"><i class="nav-icon fas fa-credit-card"></i><p>Make Other Payment</p></a></li>

    <li class="nav-item"><a href="/applicant/application/return" class="nav-link <%= path.startsWith('/applicant/application/return') ? 'active' : '' %>"><i class="nav-icon fas fa-undo"></i><p>My Application(s)</p></a></li>
    <li class="nav-item"><a href="/applicant/payments/history" class="nav-link <%= path.startsWith('/applicant/payments/history') ? 'active' : '' %>"><i class="nav-icon fas fa-receipt"></i><p>Payment History</p></a></li>
    <li class="nav-item"><a href="/applicant/result/check" class="nav-link <%= path.startsWith('/applicant/result') ? 'active' : '' %>"><i class="nav-icon fas fa-file-alt"></i><p>Check Result</p></a></li>

    <li class="nav-item has-treeview <%= path.startsWith('/applicant/exam-date') ? 'menu-open' : '' %>">
      <a href="#" class="nav-link <%= path.startsWith('/applicant/exam-date') ? 'active' : '' %>">
        <i class="nav-icon fas fa-calendar-alt"></i><p>Entrance Exam Date<i class="right fas fa-angle-left"></i></p>
      </a>
      <ul class="nav nav-treeview">
        <li class="nav-item"><a href="/applicant/exam-date/view" class="nav-link"><i class="far fa-circle nav-icon"></i><p>View</p></a></li>
      </ul>
    </li>

    <li class="nav-item">
      <a href="/applicant/uniform" class="nav-link <%= path.startsWith('/applicant/uniform') ? 'active' : '' %>">
        <i class="nav-icon fas fa-ruler"></i><p>Uniform Measurement</p>
      </a>
    </li>

  </ul>
</nav>
