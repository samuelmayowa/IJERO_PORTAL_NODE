<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title><%= typeof title === 'string' ? title : 'Staff Vacancy Application' %></title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="csrf-token" content="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">

  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.5.2/dist/css/bootstrap.min.css" crossorigin="anonymous">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">

  <style>
    :root{
      --brand-green:#247D57;
      --brand-green-deep:#195741;
      --brand-blue:#1f68c1;
      --brand-blue-soft:#eaf3ff;
      --brand-wine:#82103C;
      --ink:#1b2533;
      --muted:#6b7280;
      --line:#dbe3ee;
      --bg:#f4f8fc;
      --danger:#c0392b;
      --success:#1e824c;
      --warning:#f39c12;
    }

    *{box-sizing:border-box;}
    html,body{height:100%;}
    body{
      margin:0;
      font-family:"Segoe UI", Roboto, Arial, sans-serif;
      color:var(--ink);
      background:
        linear-gradient(rgba(255,255,255,.90), rgba(255,255,255,.92)),
        url('/public/img/login-bg.jpg') center/cover no-repeat fixed;
    }

    .page-shell{
      min-height:100vh;
      padding:28px 14px 50px;
    }

    .topbar{
      max-width:1180px;
      margin:0 auto 18px;
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:1rem;
      flex-wrap:wrap;
    }

    .brand-wrap{
      display:flex;
      align-items:center;
      gap:12px;
    }

    .brand-wrap img{
      width:62px;
      height:62px;
      object-fit:contain;
      border-radius:50%;
      background:#fff;
      border:2px solid rgba(36,125,87,.18);
      padding:6px;
      box-shadow:0 6px 18px rgba(0,0,0,.08);
    }

    .brand-text h1{
      margin:0;
      font-size:1.2rem;
      color:var(--brand-green-deep);
      font-weight:800;
      line-height:1.2;
    }

    .brand-text p{
      margin:4px 0 0;
      color:var(--muted);
      font-size:.93rem;
    }

    .top-actions a{
      display:inline-flex;
      align-items:center;
      gap:8px;
      text-decoration:none;
      background:#fff;
      color:var(--brand-green-deep);
      border:1px solid rgba(36,125,87,.16);
      border-radius:999px;
      padding:10px 16px;
      font-weight:700;
      box-shadow:0 8px 24px rgba(0,0,0,.05);
    }

    .top-actions a:hover{
      text-decoration:none;
      color:var(--brand-green-deep);
    }

    .hero-card{
      max-width:1180px;
      margin:0 auto 20px;
      border-radius:22px;
      overflow:hidden;
      background:linear-gradient(135deg, rgba(25,87,65,.98), rgba(31,104,193,.92));
      color:#fff;
      box-shadow:0 22px 60px rgba(21,50,84,.18);
      position:relative;
    }

    .hero-card::after{
      content:"";
      position:absolute;
      inset:auto -80px -80px auto;
      width:220px;
      height:220px;
      background:rgba(255,255,255,.08);
      border-radius:50%;
    }

    .hero-inner{
      display:grid;
      grid-template-columns:1.3fr .9fr;
      gap:24px;
      padding:30px 28px;
      position:relative;
      z-index:1;
    }

    .hero-kicker{
      display:inline-block;
      padding:6px 12px;
      background:rgba(255,255,255,.14);
      border:1px solid rgba(255,255,255,.16);
      border-radius:999px;
      font-size:.85rem;
      font-weight:700;
      letter-spacing:.03em;
      margin-bottom:14px;
    }

    .hero-title{
      font-size:2rem;
      line-height:1.18;
      margin:0 0 10px;
      font-weight:800;
    }

    .hero-text{
      max-width:760px;
      color:rgba(255,255,255,.92);
      font-size:1rem;
      line-height:1.6;
      margin:0;
    }

    .hero-points{
      display:grid;
      gap:12px;
      align-content:start;
    }

    .hero-point{
      background:rgba(255,255,255,.10);
      border:1px solid rgba(255,255,255,.14);
      border-radius:16px;
      padding:14px 16px;
    }

    .hero-point strong{
      display:block;
      margin-bottom:4px;
      font-size:.95rem;
    }

    .content-grid{
      max-width:1180px;
      margin:0 auto;
      display:grid;
      grid-template-columns:1.45fr .75fr;
      gap:22px;
    }

    .glass-card{
      background:rgba(255,255,255,.94);
      border:1px solid rgba(255,255,255,.65);
      border-radius:22px;
      box-shadow:0 18px 45px rgba(34,52,84,.08);
      overflow:hidden;
    }

    .card-head{
      padding:20px 22px;
      border-bottom:1px solid var(--line);
      background:linear-gradient(180deg, rgba(31,104,193,.06), rgba(36,125,87,.03));
    }

    .card-head h2{
      margin:0;
      font-size:1.22rem;
      font-weight:800;
      color:var(--ink);
    }

    .card-head p{
      margin:6px 0 0;
      color:var(--muted);
    }

    .card-body{
      padding:22px;
    }

    .form-section-title{
      display:flex;
      align-items:center;
      gap:10px;
      font-size:1rem;
      font-weight:800;
      color:var(--brand-green-deep);
      margin:0 0 14px;
    }

    .form-grid{
      display:grid;
      grid-template-columns:repeat(2, minmax(0, 1fr));
      gap:16px;
    }

    .full-span{
      grid-column:1 / -1;
    }

    .form-group label{
      font-weight:700;
      color:#243245;
      margin-bottom:8px;
    }

    .form-control,
    .custom-select{
      min-height:50px;
      border-radius:12px;
      border:1px solid #d8e1ea;
      box-shadow:none !important;
    }

    textarea.form-control{
      min-height:110px;
      resize:vertical;
    }

    .form-control:focus,
    .custom-select:focus{
      border-color:#7eb1ea;
      box-shadow:0 0 0 3px rgba(31,104,193,.12) !important;
    }

    .field-note{
      display:block;
      margin-top:6px;
      color:var(--muted);
      font-size:.84rem;
    }

    .upload-grid{
      display:grid;
      grid-template-columns:repeat(3, minmax(0, 1fr));
      gap:14px;
    }

    .upload-card{
      border:1px dashed #bed2ea;
      background:#f8fbff;
      border-radius:16px;
      padding:16px;
      min-height:100%;
    }

    .upload-card .icon{
      width:44px;
      height:44px;
      border-radius:12px;
      background:var(--brand-blue-soft);
      color:var(--brand-blue);
      display:flex;
      align-items:center;
      justify-content:center;
      font-size:1.1rem;
      margin-bottom:10px;
    }

    .upload-card h4{
      margin:0 0 6px;
      font-size:1rem;
      font-weight:800;
    }

    .upload-card p{
      margin:0 0 12px;
      color:var(--muted);
      font-size:.9rem;
      line-height:1.45;
    }

    .upload-card input[type="file"]{
      display:block;
      width:100%;
      font-size:.92rem;
    }

    .check-wrap{
      display:flex;
      align-items:flex-start;
      gap:10px;
      padding:14px 16px;
      border-radius:14px;
      background:#f7fbf9;
      border:1px solid #dcefe5;
    }

    .check-wrap input{
      margin-top:4px;
    }

    .action-row{
      display:flex;
      align-items:center;
      gap:12px;
      flex-wrap:wrap;
      margin-top:20px;
    }

    .btn-submit{
      min-width:220px;
      border:0;
      border-radius:12px;
      background:linear-gradient(135deg, var(--brand-wine), #a20d4a);
      color:#fff;
      font-weight:800;
      padding:13px 20px;
      box-shadow:0 14px 28px rgba(130,16,60,.18);
    }

    .btn-submit:hover{
      color:#fff;
      filter:brightness(.98);
    }

    .btn-light-alt{
      border-radius:12px;
      padding:12px 18px;
      font-weight:700;
      border:1px solid #d8e1ea;
      background:#fff;
      color:#223147;
    }

    .tiny-meta{
      color:var(--muted);
      font-size:.88rem;
    }

    .alert-box{
      display:none;
      margin-bottom:18px;
      border-radius:14px;
      padding:14px 16px;
      font-weight:600;
      border:1px solid transparent;
    }

    .alert-box.show{display:block;}
    .alert-box.alert-danger{
      background:#fff5f3;
      border-color:#f2c0b8;
      color:#8b2c1d;
    }
    .alert-box.alert-success{
      background:#edf9f1;
      border-color:#bfe2c8;
      color:#1d6a38;
    }
    .alert-box.alert-warning{
      background:#fff9ed;
      border-color:#f7ddb1;
      color:#8a5a00;
    }

    .invalid-feedback{
      display:block;
      margin-top:6px;
      font-size:.84rem;
      font-weight:600;
    }

    .info-stack{
      display:grid;
      gap:16px;
    }

    .info-box{
      border-radius:18px;
      padding:18px;
      background:rgba(255,255,255,.94);
      border:1px solid var(--line);
      box-shadow:0 14px 34px rgba(34,52,84,.06);
    }

    .info-box h3{
      margin:0 0 10px;
      font-size:1rem;
      font-weight:800;
      color:var(--brand-green-deep);
    }

    .info-box p,
    .info-box li{
      color:#4e5e72;
      font-size:.94rem;
      line-height:1.55;
    }

    .info-box ul{
      padding-left:18px;
      margin:0;
    }

    .pill{
      display:inline-flex;
      align-items:center;
      gap:8px;
      padding:8px 12px;
      border-radius:999px;
      background:var(--brand-blue-soft);
      color:var(--brand-blue);
      font-weight:700;
      font-size:.85rem;
      margin-bottom:8px;
    }

    .requirement-box{
      margin-top:18px;
      border:1px solid #dbe7f2;
      border-radius:18px;
      overflow:hidden;
      background:#fbfdff;
    }

    .requirement-head{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:12px;
      padding:16px 18px;
      background:linear-gradient(180deg, rgba(31,104,193,.06), rgba(36,125,87,.03));
      border-bottom:1px solid #dbe7f2;
    }

    .requirement-head h4{
      margin:0;
      font-size:1rem;
      font-weight:800;
      color:#174a8a;
    }

    .requirement-head p{
      margin:4px 0 0;
      color:var(--muted);
      font-size:.9rem;
    }

    .requirement-list{
      display:grid;
      max-height:420px;
      overflow:auto;
    }

    .requirement-row{
      display:grid;
      grid-template-columns:110px 1fr;
      gap:12px;
      align-items:center;
      padding:14px 18px;
      border-bottom:1px solid #edf2f7;
    }

    .requirement-row:last-child{
      border-bottom:none;
    }

    .req-title{
      font-weight:700;
      color:#26374c;
      line-height:1.5;
    }

    .btn-view-req{
      border:0;
      border-radius:10px;
      background:linear-gradient(135deg, #1f68c1, #2f80ed);
      color:#fff;
      font-weight:800;
      padding:10px 14px;
      box-shadow:0 10px 24px rgba(31,104,193,.14);
    }

    .btn-view-req:hover{
      color:#fff;
      filter:brightness(.98);
    }

    .modal-shell{
      position:fixed;
      inset:0;
      display:none;
      align-items:center;
      justify-content:center;
      padding:18px;
      z-index:9999;
    }

    .modal-shell.open{
      display:flex;
    }

    .modal-backdrop{
      position:absolute;
      inset:0;
      background:rgba(10,18,30,.40);
    }

    .modal-card{
      position:relative;
      z-index:10;
      width:min(760px, 100%);
      border-radius:24px;
      overflow:hidden;
      background:#ffffff;
      box-shadow:0 28px 80px rgba(0,0,0,.28);
      max-height:90vh;
      overflow-y:auto;
      opacity:1 !important;
      filter:none !important;
      backdrop-filter:none !important;
      transform:translateZ(0);
      isolation:isolate;
      pointer-events:auto;
    }

    .modal-card *{
      filter:none !important;
      backdrop-filter:none !important;
    }

    .modal-top{
      padding:24px 24px 18px;
      text-align:center;
      background:linear-gradient(135deg, rgba(31,104,193,.95), rgba(36,125,87,.96));
      color:#fff;
    }

    .success-icon{
      width:74px;
      height:74px;
      margin:0 auto 12px;
      border-radius:50%;
      background:rgba(255,255,255,.16);
      border:1px solid rgba(255,255,255,.22);
      display:flex;
      align-items:center;
      justify-content:center;
      font-size:2rem;
    }

    .modal-top h3{
      margin:0;
      font-size:1.45rem;
      font-weight:800;
    }

    .modal-top p{
      margin:8px auto 0;
      max-width:560px;
      color:rgba(255,255,255,.92);
    }

    .modal-body{
      padding:22px;
    }

    .summary-grid{
      display:grid;
      grid-template-columns:repeat(2, minmax(0, 1fr));
      gap:12px;
      margin-bottom:18px;
    }

    .summary-item{
      border:1px solid var(--line);
      border-radius:14px;
      padding:14px;
      background:#fbfdff;
    }

    .summary-item .k{
      font-size:.82rem;
      color:var(--muted);
      text-transform:uppercase;
      letter-spacing:.04em;
      margin-bottom:5px;
      font-weight:700;
    }

    .summary-item .v{
      font-weight:800;
      color:#223147;
      line-height:1.45;
      word-break:break-word;
    }

    .modal-actions{
      display:flex;
      gap:12px;
      flex-wrap:wrap;
      align-items:center;
    }

    .modal-actions-top{
      justify-content:flex-end;
      padding:4px 0 2px;
    }

    .btn-print{
      background:linear-gradient(135deg, var(--brand-blue), #4285f4);
      color:#fff;
      border:0;
      border-radius:12px;
      padding:12px 18px;
      font-weight:800;
      cursor:pointer;
    }

    .btn-print:hover{color:#fff;}

    .btn-close-modal{
      background:#fff;
      color:#223147;
      border:1px solid #d8e1ea;
      border-radius:12px;
      padding:12px 18px;
      font-weight:800;
      cursor:pointer;
    }

    .req-modal-copy{
      white-space:pre-line;
      color:#24364a;
      line-height:1.8;
      font-size:1rem;
      background:#ffffff;
      border:1px solid #dbe7f8;
      border-radius:16px;
      padding:18px;
    }

    #printSheet{
      display:none;
    }

    .print-slip{
      position:relative;
      background:#ffffff;
      border:1px solid #b9d0f5;
      border-radius:24px;
      overflow:hidden;
      padding:28px;
      filter:none !important;
      backdrop-filter:none !important;
      opacity:1 !important;
    }

    .print-slip::before{
      content:attr(data-watermark);
      position:absolute;
      inset:0;
      display:flex;
      align-items:center;
      justify-content:center;
      font-size:3rem;
      line-height:1.1;
      text-align:center;
      color:rgba(31,104,193,.10);
      font-weight:900;
      letter-spacing:.08em;
      transform:rotate(-24deg);
      pointer-events:none;
      padding:30px;
    }

    .print-head{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:16px;
      margin-bottom:18px;
      position:relative;
      z-index:1;
    }

    .print-head .left{
      display:flex;
      align-items:center;
      gap:14px;
    }

    .print-head img{
      width:62px;
      height:62px;
      object-fit:contain;
    }

    .print-head h4{
      margin:0;
      font-size:1.08rem;
      color:#174a8a;
      font-weight:900;
    }

    .print-head p{
      margin:4px 0 0;
      color:#44627a;
      font-size:.9rem;
    }

    .print-badge{
      padding:10px 14px;
      border-radius:999px;
      background:#eef5ff;
      color:#1f68c1;
      font-weight:800;
      border:1px solid #c9dbfb;
      white-space:nowrap;
    }

    .print-body{
      position:relative;
      z-index:1;
      border-top:1px solid #dbe7fb;
      padding-top:18px;
    }

    .print-row{
      display:grid;
      grid-template-columns:220px 1fr;
      gap:12px;
      padding:9px 0;
      border-bottom:1px dashed #dbe7fb;
    }

    .print-row .label{
      color:#5a6c82;
      font-weight:700;
    }

    .print-row .value{
      color:#213249;
      font-weight:800;
      word-break:break-word;
    }

    .print-foot{
      position:relative;
      z-index:1;
      margin-top:16px;
      color:#51657d;
      font-size:.92rem;
      line-height:1.55;
    }

    .spinner-border-sm{
      margin-right:8px;
    }

    @media (max-width: 991px){
      .hero-inner,
      .content-grid{
        grid-template-columns:1fr;
      }
    }

    @media (max-width: 767px){
      .form-grid,
      .upload-grid,
      .summary-grid{
        grid-template-columns:1fr;
      }

      .print-row,
      .requirement-row{
        grid-template-columns:1fr;
        gap:4px;
      }

      .hero-title{
        font-size:1.6rem;
      }
    }

    @media print{
      body *{
        visibility:hidden !important;
      }

      #printSheet,
      #printSheet *{
        visibility:visible !important;
      }

      #printSheet{
        display:block !important;
        position:absolute;
        inset:0;
        width:100%;
        padding:18px;
      }

      .print-slip{
        box-shadow:none !important;
        border-color:#9ebdea !important;
      }
    }
  </style>
</head>
<body>
  <div class="page-shell">
    <div class="topbar">
      <div class="brand-wrap">
        <img src="/public/img/logo.png" alt="EKSCOTECH logo">
        <div class="brand-text">
          <h1><%= institutionName %></h1>
          <p>Welcome to the College staff vacancy application portal</p>
        </div>
      </div>

      <div class="top-actions">
        <a href="/"><i class="fa fa-home"></i> Back to Homepage</a>
      </div>
    </div>

    <section class="hero-card">
      <div class="hero-inner">
        <div>
          <span class="hero-kicker"><i class="fa fa-briefcase"></i> Staff Vacancy Application</span>
          <h2 class="hero-title">Please check back later</h2>
          <p class="hero-text">
            Application currently not available.
          </p>
        </div>

        
</body>
</html>