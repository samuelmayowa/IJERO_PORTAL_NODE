<%
const sess =
  typeof currentSession !== 'undefined' &&
  currentSession
    ? currentSession
    : { name: 'Session' };

const paid = Number(
  typeof totalPaid !== 'undefined'
    ? totalPaid
    : 0
);

const submittedCount = Number(
  typeof submittedApplications !== 'undefined'
    ? submittedApplications
    : 0
);

const inProgressCount = Number(
  typeof inProgressApplications !== 'undefined'
    ? inProgressApplications
    : 0
);

const breakdown =
  typeof paymentsBreakdown !== 'undefined' &&
  paymentsBreakdown
    ? paymentsBreakdown
    : {
        application: 0,
        acceptance: 0
      };

const recentApps =
  typeof recentApplications !== 'undefined' &&
  Array.isArray(recentApplications)
    ? recentApplications
    : [];

const recentPays =
  typeof recentPayments !== 'undefined' &&
  Array.isArray(recentPayments)
    ? recentPayments
    : [];

function money(value) {
  return Number(value || 0).toLocaleString(
    'en-NG',
    {
      minimumFractionDigits: 2,
      maximumFractionDigits: 2
    }
  );
}

function displayDate(value) {
  if (!value) return '-';

  const date = new Date(value);

  if (Number.isNaN(date.getTime())) {
    return '-';
  }

  return date.toLocaleDateString(
    'en-GB',
    {
      day: '2-digit',
      month: 'short',
      year: 'numeric'
    }
  );
}

function statusClass(status) {
  const normalized = String(status || '')
    .toUpperCase();

  if (
    [
      'PAID',
      'SUBMITTED',
      'ADMITTED'
    ].includes(normalized)
  ) {
    return 'badge-success';
  }

  if (
    [
      'PENDING',
      'AWAITING_PAYMENT',
      'UNDER_REVIEW',
      'IN_PROGRESS'
    ].includes(normalized)
  ) {
    return 'badge-warning';
  }

  if (
    [
      'FAILED',
      'REJECTED'
    ].includes(normalized)
  ) {
    return 'badge-danger';
  }

  return 'badge-secondary';
}
%>

<div class="row">
  <div class="col-12 col-sm-6 col-md-3">
    <div class="small-box bg-info">
      <div class="inner">
        <h3><%= sess.name %></h3>
        <p>Current Admission Session</p>
      </div>

      <div class="icon">
        <i class="fas fa-calendar"></i>
      </div>
    </div>
  </div>

  <div class="col-12 col-sm-6 col-md-3">
    <div class="small-box bg-success">
      <div class="inner">
        <h3>₦<%= money(paid) %></h3>

        <p>Total Amount Paid</p>

        <p class="mb-0 text-sm">
          Application Fee:
          ₦<%= money(breakdown.application) %>
          <br>

          Acceptance Fee:
          ₦<%= money(breakdown.acceptance) %>

          <br>

          <a
            href="/applicant/payments/history"
            class="text-dark"
          >
            <strong>View payment history</strong>
          </a>
        </p>
      </div>

      <div class="icon">
        <i class="fas fa-wallet"></i>
      </div>
    </div>
  </div>

  <div class="col-12 col-sm-6 col-md-3">
    <div class="small-box bg-warning">
      <div class="inner">
        <h3><%= submittedCount %></h3>
        <p>Total Submitted Applications</p>
      </div>

      <div class="icon">
        <i class="fas fa-file-check"></i>
      </div>
    </div>
  </div>

  <div class="col-12 col-sm-6 col-md-3">
    <div class="small-box bg-danger">
      <div class="inner">
        <h3><%= inProgressCount %></h3>
        <p>Total In-Progress Applications</p>
      </div>

      <div class="icon">
        <i class="fas fa-edit"></i>
      </div>
    </div>
  </div>
</div>

<div class="row">
  <div class="col-lg-8">
    <div class="card card-success">
      <div class="card-header">
        <h3 class="card-title">
          <i class="fas fa-file-signature mr-2"></i>
          Recent Application(s)
        </h3>

        <div class="card-tools">
          <a
            href="/applicant/application/return"
            class="btn btn-sm btn-outline-light"
          >
            My Application(s)
          </a>
        </div>
      </div>

      <div class="card-body p-0">
        <div class="table-responsive">
          <table
            class="table table-striped table-hover mb-0"
          >
            <thead>
              <tr>
                <th style="width:60px">#</th>
                <th>Application</th>
                <th>Type</th>
                <th>Status</th>
                <th style="width:140px">Date</th>
              </tr>
            </thead>

            <tbody>
              <% if (!recentApps.length) { %>
                <tr>
                  <td
                    colspan="5"
                    class="text-muted p-3"
                  >
                    No recent applications.
                  </td>
                </tr>
              <% } else { %>
                <% recentApps.forEach((item, index) => { %>
                  <tr>
                    <td><%= index + 1 %></td>

                    <td>
                      <a
                        href="/applicant/applications/<%= encodeURIComponent(
                          item.slug
                        ) %>"
                      >
                        <strong>
                          <%= item.title || '-' %>
                        </strong>
                      </a>

                      <div class="small text-muted">
                        <%= item.application_number || '-' %>
                      </div>
                    </td>

                    <td>
                      <%= item.category || '-' %>
                    </td>

                    <td>
                      <span
                        class="badge <%= statusClass(
                          item.status
                        ) %>"
                      >
                        <%= String(
                          item.status || '-'
                        ).replaceAll('_', ' ') %>
                      </span>
                    </td>

                    <td>
                      <%= displayDate(
                        item.submitted_at ||
                        item.created_at
                      ) %>
                    </td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <div class="col-lg-4">
    <div class="card">
      <div class="card-header">
        <h3 class="card-title">
          <i class="fas fa-info-circle mr-2"></i>
          Announcements
        </h3>
      </div>

      <div class="card-body">
        <p class="text-muted mb-0">
          Application and admission updates will appear here.
        </p>
      </div>
    </div>
  </div>
</div>

<div class="row">
  <div class="col-lg-12">
    <div class="card card-outline card-success">
      <div class="card-header">
        <h3 class="card-title">
          <i class="fas fa-receipt mr-2"></i>
          Recent Payment History
        </h3>

        <div class="card-tools">
          <a
            href="/applicant/payments/history"
            class="btn btn-sm btn-outline-success"
          >
            Open Full History
          </a>
        </div>
      </div>

      <div class="card-body p-0">
        <div class="table-responsive">
          <table
            class="table table-striped table-hover mb-0"
          >
            <thead>
              <tr>
                <th style="width:60px">#</th>
                <th>RRR</th>
                <th>Purpose</th>
                <th>Type</th>
                <th>Amount</th>
                <th>Status</th>
                <th style="width:140px">Date</th>
                <th style="width:120px">Action</th>
              </tr>
            </thead>

            <tbody>
              <% if (!recentPays.length) { %>
                <tr>
                  <td
                    colspan="8"
                    class="text-muted p-3"
                  >
                    No recent payments.
                  </td>
                </tr>
              <% } else { %>
                <% recentPays.forEach((payment, index) => { %>
                  <tr>
                    <td><%= index + 1 %></td>

                    <td>
                      <%= payment.rrr || '-' %>
                    </td>

                    <td>
                      <%= payment.purpose || '-' %>
                    </td>

                    <td>
                      <%= String(
                        payment.payment_stage || '-'
                      ).replaceAll('_', ' ') %>
                    </td>

                    <td>
                      ₦<%= money(
                        Number(payment.amount || 0) +
                        Number(payment.portal_charge || 0)
                      ) %>
                    </td>

                    <td>
                      <span
                        class="badge <%= statusClass(
                          payment.status
                        ) %>"
                      >
                        <%= payment.status || 'PENDING' %>
                      </span>
                    </td>

                    <td>
                      <%= displayDate(
                        payment.paid_at ||
                        payment.created_at
                      ) %>
                    </td>

                    <td>
                      <% if (
                        String(
                          payment.status || ''
                        ).toUpperCase() === 'PAID' &&
                        payment.order_id
                      ) { %>
                        <a
                          href="/payment/print/<%= encodeURIComponent(
                            payment.order_id
                          ) %>?type=receipt&dl=0"
                          target="_blank"
                          class="btn btn-success btn-sm"
                        >
                          Receipt
                        </a>
                      <% } else { %>
                        <span class="text-muted">—</span>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>
