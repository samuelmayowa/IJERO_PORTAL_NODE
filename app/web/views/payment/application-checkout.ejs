<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta
    name="viewport"
    content="width=device-width,initial-scale=1"
  >

  <title>Application Payment</title>

  <style>
    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      padding: 24px;
      font-family:
        system-ui, -apple-system, BlinkMacSystemFont,
        "Segoe UI", sans-serif;
      background: #f3f6f9;
      color: #1f2937;
    }

    .page {
      max-width: 820px;
      margin: 35px auto;
    }

    .card {
      background: #fff;
      border-radius: 14px;
      box-shadow: 0 14px 45px rgba(0, 0, 0, .09);
      overflow: hidden;
    }

    .header {
      padding: 24px 28px;
      color: #fff;
      background: linear-gradient(135deg, #16744a 0%, #8a0d3f 100%);
    }

    .header h1 {
      margin: 0 0 5px;
      font-size: 25px;
    }

    .header p {
      margin: 0;
      opacity: .9;
    }

    .body {
      padding: 28px;
    }

    .summary {
      width: 100%;
      margin-bottom: 24px;
      border-collapse: collapse;
    }

    .summary th,
    .summary td {
      padding: 12px;
      border: 1px solid #dce3e8;
      text-align: left;
    }

    .summary th {
      width: 37%;
      background: #f7f9fb;
    }

    .amount {
      font-size: 25px;
      font-weight: 750;
      color: #16744a;
    }

    .methods {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 18px;
      margin-top: 20px;
    }

    .method {
      padding: 21px;
      border: 1px solid #dce3e8;
      border-radius: 12px;
    }

    .method h3 {
      margin: 0 0 8px;
    }

    .method p {
      min-height: 48px;
      margin: 0 0 17px;
      color: #64748b;
      line-height: 1.5;
    }

    button,
    .button {
      display: inline-block;
      width: 100%;
      padding: 12px 16px;
      border: 0;
      border-radius: 8px;
      text-decoration: none;
      text-align: center;
      font-size: 15px;
      font-weight: 700;
      cursor: pointer;
    }

    .online {
      color: #fff;
      background: #8a0d3f;
    }

    .online:hover {
      background: #700a33;
    }

    .bank {
      color: #111827;
      background: #e5e7eb;
    }

    .footer {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      margin-top: 25px;
    }

    .footer a {
      color: #475569;
      text-decoration: none;
    }

    .alert {
      margin-bottom: 18px;
      padding: 12px 15px;
      border-radius: 8px;
      color: #991b1b;
      background: #fef2f2;
      border: 1px solid #fecaca;
    }

    @media (max-width: 650px) {
      .methods {
        grid-template-columns: 1fr;
      }

      body {
        padding: 12px;
      }

      .body {
        padding: 20px;
      }
    }
  </style>
</head>

<body>
  <main class="page">
    <section class="card">
      <header class="header">
        <h1>Application Payment</h1>
        <p>
          Select how you would like to complete your payment.
        </p>
      </header>

      <div class="body">
        <%
          const errorMessage =
            messages &&
            Array.isArray(messages.error)
              ? messages.error[0]
              : messages?.error;
        %>

        <% if (errorMessage) { %>
          <div class="alert"><%= errorMessage %></div>
        <% } %>

        <table class="summary">
          <tr>
            <th>Application</th>
            <td><%= invoice.application_title %></td>
          </tr>

          <tr>
            <th>Applicant</th>
            <td><%= invoice.payee_fullname %></td>
          </tr>

          <tr>
            <th>Order ID</th>
            <td><%= invoice.order_id %></td>
          </tr>

          <tr>
            <th>RRR</th>
            <td>
              <strong>
                <%= invoice.rrr ||
                  'Generated after selecting a payment method' %>
              </strong>
            </td>
          </tr>

          <tr>
            <th>Total Payable</th>
            <td class="amount">
              ₦<%= Number(total).toLocaleString(
                'en-NG',
                {
                  minimumFractionDigits: 2,
                  maximumFractionDigits: 2
                }
              ) %>
            </td>
          </tr>
        </table>

        <div class="methods">
          <div class="method">
            <h3>Continue to Payment</h3>

            <p>
              Open the portal payment page and choose Pay Online
              or Pay at Bank Branch.
            </p>

            <form
              method="POST"
              action="/payment/application/<%= encodeURIComponent(
                invoice.order_id
              ) %>/online"
            >
              <input
                type="hidden"
                name="_csrf"
                value="<%= csrfToken %>"
              >

              <button class="online" type="submit">
                Continue to Payment Options
              </button>
            </form>
          </div>

          <div class="method">
            <h3>Pay at a Bank</h3>

            <p>
              Print the invoice containing your RRR and make payment
              at a supported bank or through another Remita channel.
            </p>

            <form
              method="POST"
              action="/payment/application/<%= encodeURIComponent(
                invoice.order_id
              ) %>/bank"
            >
              <input
                type="hidden"
                name="_csrf"
                value="<%= csrfToken %>"
              >

              <button class="bank" type="submit">
                View and Print Invoice
              </button>
            </form>
          </div>
        </div>

        <div class="footer">
          <a href="<%= backUrl %>">← Back to Application</a>

          <a
            href="/payment/reprint?rrr=<%= encodeURIComponent(
              invoice.rrr
            ) %>"
          >
            Validate Existing Payment
          </a>
        </div>
      </div>
    </section>
  </main>
</body>
</html>
